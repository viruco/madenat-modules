<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ✅ SOLO DEFINICIONES DE ACCIONES - SIN TEMPLATES DUPLICADOS -->
    
    <!-- Acción para Reporte de Tarjas por Lote -->
    <record id="action_report_lumber_batch" model="ir.actions.report">
        <field name="name">Tarja por Lote</field>
        <field name="model">stock.lot</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">madenat_lumber_core.report_lumber_batch</field>
        <field name="print_report_name">'Tarja - %s' % (object.name)</field>
        <field name="binding_model_id" ref="stock.model_stock_lot"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Acción para Reporte de Costeo por Lote -->
    <record id="action_report_lumber_cost" model="ir.actions.report">
        <field name="name">Informe de Costeo por Lote</field>
        <field name="model">stock.lot</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">madenat_lumber_core.report_lumber_cost</field>
        <field name="print_report_name">'Costeo - %s' % (object.name)</field>
        <field name="binding_model_id" ref="stock.model_stock_lot"/>
        <field name="binding_type">report</field>
    </record>
</odoo>