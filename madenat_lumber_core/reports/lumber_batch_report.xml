<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_lumber_batch">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="lot">
                <div class="page" style="font-family: Arial, sans-serif; margin: 20px;">
                    <!-- ENCABEZADO -->
                    <div style="border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 20px;">
                        <h1 style="color: #2c3e50; margin: 0;">TARJA MADENAT</h1>
                        <h2 style="color: #7f8c8d; margin: 5px 0 0 0;">Identificación de Lote</h2>
                    </div>
                    
                    <!-- INFORMACIÓN BÁSICA -->
                    <table style="width: 100%; margin-bottom: 20px;">
                        <tr>
                            <td style="width: 50%; vertical-align: top;">
                                <strong>Información del Lote:</strong><br/>
                                N° Tarja: <span t-field="lot.name"/><br/>
                                Producto: <span t-field="lot.product_id.display_name"/><br/>
                                Recepción: <span t-field="lot.reception_id.name"/><br/>
                                Fecha Recepción: <span t-field="lot.reception_id.reception_date" t-options='{"format": "dd/MM/yyyy"}'/>
                            </td>
                            <td style="width: 50%; vertical-align: top;">
                                <strong>Origen:</strong><br/>
                                Orden Compra: <span t-field="lot.reception_id.purchase_order"/><br/>
                                Proveedor: <span t-field="lot.reception_id.supplier_id.name"/><br/>
                                RUT: <span t-field="lot.reception_id.supplier_id.vat"/>
                            </td>
                        </tr>
                    </table>
                    
                    <!-- ESPECIFICACIONES TÉCNICAS -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                        <thead>
                            <tr style="background-color: #34495e; color: white;">
                                <th style="padding: 8px; border: 1px solid #ddd;">Espesor (mm)</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Ancho (mm)</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Largo (m)</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Piezas</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Volumen m³</th>
                                <th style="padding: 8px; border: 1px solid #ddd;">Volumen MBF</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><span t-field="lot.espesor_mm"/></td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><span t-field="lot.ancho_mm"/></td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><span t-field="lot.largo_m"/></td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><span t-field="lot.piezas"/></td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><span t-field="lot.volumen_m3"/></td>
                                <td style="padding: 8px; border: 1px solid #ddd; text-align: center;"><span t-field="lot.volumen_mbf"/></td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <!-- VALIDACIONES -->
                    <table style="width: 100%; margin-bottom: 20px;">
                        <tr>
                            <td style="width: 50%;">
                                <strong>Validación Técnica:</strong> 
                                <span t-if="lot.technical_validation == 'approved'" style="color: green;">✓ APROBADO</span>
                                <span t-elif="lot.technical_validation == 'rejected'" style="color: red;">✗ RECHAZADO</span>
                                <span t-else="" style="color: orange;">⏰ PENDIENTE</span>
                            </td>
                            <td style="width: 50%;">
                                <strong>Validación Financiera:</strong> 
                                <span t-if="lot.financial_validation == 'approved'" style="color: green;">✓ APROBADO</span>
                                <span t-elif="lot.financial_validation == 'rejected'" style="color: red;">✗ RECHAZADO</span>
                                <span t-else="" style="color: orange;">⏰ PENDIENTE</span>
                            </td>
                        </tr>
                    </table>
                    
                    <!-- FIRMAS -->
                    <table style="width: 100%; margin-top: 40px;">
                        <tr>
                            <td style="width: 50%; text-align: center; border-top: 1px solid #333; padding-top: 10px;">
                                Responsable Técnico
                            </td>
                            <td style="width: 50%; text-align: center; border-top: 1px solid #333; padding-top: 10px;">
                                Responsable Financiero
                            </td>
                        </tr>
                    </table>
                    
                    <!-- PIE DE PÁGINA -->
                    <div style="margin-top: 30px; font-size: 10px; color: #7f8c8d; text-align: center;">
                        Generado el <span t-esc="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/> | 
                        MADENAT Lumber System
                    </div>
                </div>
                
                <!-- SALTO DE PÁGINA ENTRE LOTES (excepto el último) -->
                <t t-if="lot_index &lt; len(docs)-1">
                    <div style="page-break-after: always;"></div>
                </t>
            </t>
        </t>
    </template>
</odoo>