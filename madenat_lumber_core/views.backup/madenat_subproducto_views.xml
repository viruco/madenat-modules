<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de lista -->
    <record id="view_madenat_subproducto_list" model="ir.ui.view">
        <field name="name">madenat.subproducto.list</field>
        <field name="model">madenat.subproducto</field>
        <field name="arch" type="xml">
            <list string="Sub-productos">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario -->
    <record id="view_madenat_subproducto_form" model="ir.ui.view">
        <field name="name">madenat.subproducto.form</field>
        <field name="model">madenat.subproducto</field>
        <field name="arch" type="xml">
            <form string="Sub-producto">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción de menú -->
    <record id="action_madenat_subproducto" model="ir.actions.act_window">
        <field name="name">Sub-productos</field>
        <field name="res_model">madenat.subproducto</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_madenat_subproducto"
              name="Sub-productos"
              parent="stock.menu_stock_config_settings"
              action="action_madenat_subproducto"
              sequence="20"/>
</odoo>
