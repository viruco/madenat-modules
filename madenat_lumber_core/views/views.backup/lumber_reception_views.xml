<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================== -->
    <!-- VISTAS PRINCIPALES PARA LUMBER RECEPTION (Odoo 18) -->
    <!-- ================================================== -->

    <!-- VISTA LISTA (Intacta) -->
    <record id="view_lumber_reception_list" model="ir.ui.view">
        <field name="name">lumber.reception.list</field>
        <field name="model">lumber.reception</field>
        <field name="arch" type="xml">
            <list string="Recepción de Guías" 
                  decoration-danger="state == 'error'" 
                  decoration-success="state == 'done'" 
                  decoration-warning="state == 'verified'" 
                  decoration-muted="state == 'draft'"
                  decoration-info="state == 'pending_link'">
                <field name="name" string="Guía"/>
                <field name="reception_date" string="Fecha"/>
                <field name="supplier_id" string="Proveedor"/>
                <field name="purchase_order" string="Orden Compra"/>
                <field name="commercial_volume_m3" string="Vol. Comercial m³" digits="[16, 3]"/>
                <field name="physical_volume_m3" string="Vol. Físico m³" digits="[16, 3]"/>
                <field name="volume_variance_percent" string="Dif. %" widget="percentage" decoration-bf="1"/>
                <field name="total_packages" string="Paquetes"/>
                <field name="state" string="Estado" widget="badge" 
                       decoration-success="state == 'done'" 
                       decoration-warning="state == 'verified'" 
                       decoration-danger="state == 'error'"
                       decoration-info="state == 'pending_link'"/>
            </list>
        </field>
    </record>

    <!-- FORMULARIO MEJORADO (Notebook Profesional) -->
    <record id="view_lumber_reception_form" model="ir.ui.view">
        <field name="name">lumber.reception.form</field>
        <field name="model">lumber.reception</field>
        <field name="arch" type="xml">
            <form string="Recepción de Guía" class="o_xxl_form_view">
                        
                <header>
                        <!-- 1. PROCESAR (Lee Excel -> Llena Tabla Staging) -->
                        <button name="action_process_documents" 
                                string="▶️ 1. Procesar y Verificar" 
                                type="object" class="btn-primary"
                                invisible="state not in ['draft', 'verified']"/>
                        
                        <!-- 2. CONFIRMAR (Crea Lotes -> Finaliza) -->
                        <button name="action_confirm_reception" 
                                string="✅ 2. Confirmar Recepción" 
                                type="object" class="btn-success"
                                invisible="state != 'verified'"/>
                                
                        <!-- 3. SALIDAS DE EMERGENCIA -->
                        <button name="action_reset_to_draft" 
                                string="↩️ Corregir / Volver a Borrador" 
                                type="object" class="btn-secondary"
                                invisible="state == 'draft'"/>

                        <button name="action_cancel" 
                                string="🚫 Cancelar" 
                                type="object" class="btn-danger"
                                invisible="state in ['draft', 'cancel', 'done']"/>
                        
                        <field name="state" widget="statusbar" 
                            statusbar_visible="draft,verified,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ej: 39177 - N° Guía"/></h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="supplier_id"/>
                            <field name="location_id" required="1" domain="[('usage', '=', 'internal')]"/>
                            <field name="purchase_order"/>
                            <field name="reception_date"/>
                        </group>
                        <group string="Información Monetaria">
                            <field name="exchange_rate_date"/>
                            <field name="exchange_rate"/>
                            <field name="total_amount_clp"/>
                            <field name="total_amount_usd" readonly="1"/>
                        </group>
                    </group>

                    <!-- TARJETAS KPI (Volúmenes) -->
                    <div class="row mb-3">
                        <div class="col-12 col-md-6 col-lg-3 mb-3">
                            <div class="card h-100 text-center">
                                <div class="card-header bg-light"><strong>Vol. Comercial (Guía)</strong></div>
                                <div class="card-body">
                                    <h3 class="text-primary">
                                        <field name="commercial_volume_m3" readonly="1"/> m³
                                    </h3>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-12 col-md-6 col-lg-3 mb-3">
                            <div class="card h-100 text-center">
                                <div class="card-header bg-light"><strong>Vol. Físico (Medido)</strong></div>
                                <div class="card-body">
                                    <h3 class="text-success">
                                        <field name="physical_volume_m3" readonly="1"/> m³
                                    </h3>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-12 col-md-6 col-lg-3 mb-3">
                            <div class="card h-100 text-center">
                                <div class="card-header bg-light"><strong>Diferencia</strong></div>
                                <div class="card-body">
                                    <h3>
                                        <field name="volume_variance_percent" 
                                              decoration-danger="volume_variance_percent > 5"
                                              decoration-success="volume_variance_percent &lt;= 5"/> %
                                    </h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <notebook>
                        <!-- ==================================================== -->
                        <!-- PESTAÑA 1: RECEPCIÓN FÍSICA (BODEGA - STAGING)       -->
                        <!-- ==================================================== -->
                        <page string="📍 Recepción Física (Bodega)" name="staging_page" 
                              invisible="state == 'draft'"> 
                            
                            <div class="alert alert-info" role="alert" invisible="state == 'done'">
                                <i class="fa fa-info-circle"/> 
                                <strong>Revisión Previa:</strong> Estos son los datos extraídos del Excel. Verifique antes de confirmar.
                            </div>

                            <!-- CORRECCIÓN: Eliminado context='active_id' -->
                            <field name="reception_line_ids" readonly="state == 'done'">
                                <list string="Detalle Físico" editable="bottom" decoration-danger="warning_msg != False">
                                    <!-- Campos de Identificación -->
                                    <field name="lot_name" string="Lote/Etiqueta" decoration-bf="1"/>
                                    <field name="product_id"/>
                                   <!-- <field name="wood_species_id" optional="hide"/> -->

                                    <field name="quality" optional="show"/>
                                    
                                    <!-- Dimensiones REALES (mm) -->
                                    <field name="thickness" string="Esp (mm)" sum="Promedio"/>
                                    <field name="width" string="Ancho (mm)"/>
                                    <field name="length" string="Largo (m)"/>
                                    <field name="pieces" sum="Total Piezas"/>
                                    
                                    <!-- Volumen REAL -->
                                    <field name="vol_shipment_m3" string="Vol. Físico (m³)" sum="Total Físico" decoration-bf="1"/>
                                    
                                    <!-- Alertas -->
                                    <field name="warning_msg" invisible="1"/>
                                    <button name="unlink" title="Descartar" icon="fa-trash" type="delete"/>
                                </list>
                            </field>
                        </page>

                        <!-- ==================================================== -->
                        <!-- PESTAÑA 2: ANÁLISIS COMERCIAL (OC / NOMINAL)         -->
                        <!-- ==================================================== -->
                       <page string="💲 Análisis Comercial (OC)" name="commercial_check"
                        invisible="state == 'draft'">
                        
                        <!-- BARRA DE HERRAMIENTAS -->
                        <div class="btn-group mb-2">
                            <button name="%(madenat_lumber_core.action_lumber_reception_mass_update)d" 
                                    string="🛠️ Fijar Nominal (Masivo)" 
                                    type="action" 
                                    class="btn btn-secondary btn-sm"/>
                                  
                        </div>

                        <field name="reception_line_ids" readonly="1">
                            <list string="Detalle Comercial" create="0" delete="0">
                                <!-- (Tus columnas siguen igual) -->
                                <field name="lot_name" readonly="1"/>
                                <field name="product_id" readonly="1"/>
                                
                                <!-- Dimensiones NOMINALES -->
                                <field name="thickness_nominal" string="Esp. Nom (mm)" decoration-info="1"/>
                                <field name="width_nominal" string="Ancho Nom (mm)" decoration-info="1"/>
                                <field name="length" readonly="1"/>
                                <field name="pieces" readonly="1"/>
                                
                                <!-- Comparativa -->
                                <field name="vol_purchase_m3" string="Vol. Compra (m³)" sum="Total Compra" 
                                    decoration-bf="1" decoration-info="1"/>
                                <field name="estimated_cost_usd" sum="Total Costo" widget="monetary"/>
                            </list>
                        </field>
                    </page>


                        <!-- ==================================================== -->
                        <!-- PESTAÑA 3: VISTA IMPERIAL (EXPORTACIÓN)              -->
                        <!-- ==================================================== -->
                        <page string="🌎 Vista (Exportación)" name="imperial_check">
                            <!-- readonly="0" para permitir ediciones en los campos editables del modelo -->
                            <field name="reception_line_ids">
                                
                                <!-- ODOO 18: Usamos 'list' en lugar de 'tree' -->
                                <!-- editable="bottom": CLAVE para editar rápido las fracciones -->
                                <list string="Detalle de Embarque" 
                                      editable="bottom" 
                                      create="0" 
                                      delete="0" 
                                      decoration-muted="width &gt; 160">
                                    
                                    <!-- 1. CÓDIGOS / ETIQUETA -->
                                    <!-- Odoo 18: Usamos 'readonly="1"' si no queremos que editen esto -->
                                    <field name="lot_name" string="Códigos" optional="show" readonly="1"/>
                                    
                                    <!-- 2. PRODUCTO -->
                                    <field name="product_id" string="Producto" optional="show" readonly="1"/>
                                    
                                    <!-- 3. ESPESOR (Format: 6/4) -->
                                    <!-- Este campo AHORA ES EDITABLE en el modelo. Aquí se deja editar. -->
                                    <field name="thickness_visual" string="Espesor" class="text-center" decoration-bf="1"/>
                                    
                                    <!-- 4. ANCHO (Format: 5 5/8) -->
                                    <!-- AQUÍ OCURRE LA MAGIA: El usuario ve "5 5/8" calculado, pero puede borrarlo y poner "RW" -->
                                    <field name="width_visual" string="Ancho" class="text-center" decoration-bf="1"/>
                                    
                                    <!-- 5. LARGO (Format: 4000 mm) -->
                                    <field name="length_mm" string="Largo (mm)" class="text-end" readonly="1"/>
                                    
                                    <!-- 6. PIEZAS -->
                                    <field name="pieces" string="Piezas" sum="Total Piezas" readonly="1"/>
                                    
                                    <!-- 7. VOLUMEN (m3) -->
                                    <field name="vol_physical_m3" string="Volumen (m³)" 
                                           sum="Total m³" 
                                           decoration-bf="1"
                                           decoration-warning="1"
                                           readonly="1"/>
                                    
                                    <!-- 8. VOLUMEN MBF -->
                                    <field name="vol_mbf" string="Volumen (MBF)" sum="Total MBF" optional="hide" readonly="1"/>
                                    
                                    <!-- CAMPOS OCULTOS PARA CÁLCULOS -->
                                    <!-- Odoo 18: column_invisible="1" es la forma correcta de ocultar -->
                                    <field name="width" column_invisible="1"/> 
                                    <field name="thickness" column_invisible="1"/>
                                    <field name="length_ft" column_invisible="1"/>
                                    <field name="board_feet" column_invisible="1"/>
                                </list>
                            </field>
                        </page>



                        <!-- PESTAÑA 4: DOCUMENTOS (Tu original) -->
                        <page string="📂 Documentos" name="documents">
                            <group string="Carga de Archivos">
                                <group>
                                    <field name="oc_pdf_file" filename="oc_pdf_filename" widget="binary"/>
                                    <field name="oc_pdf_filename" invisible="1"/>
                                    
                                    <field name="pdf_file" filename="pdf_filename" widget="binary" required="1"/>
                                    <field name="pdf_filename" invisible="1"/>
                                </group>
                                <group>
                                    <field name="excel_file" filename="excel_filename" widget="binary" required="1"/>
                                    <field name="excel_filename" invisible="1"/>
                                    
                                    <field name="total_packages" readonly="1"/>
                                </group>
                            </group>
                            
                            <group invisible="omitted_count == 0">
                                <div class="alert alert-warning" role="alert">
                                    <strong>⚠️ Atención:</strong> Se omitieron <field name="omitted_count" readonly="1"/> líneas.
                                    <button name="action_view_audit_logs" type="object" 
                                            string="Ver Detalles" class="btn-link"/>
                                </div>
                            </group>
                            
                            <separator string="Bitácora de Proceso"/>
                            <field name="log_notes" readonly="1" widget="html"/>
                        </page>
                        
                        <!-- PESTAÑA 5: LOTES GENERADOS (Resultado Final) -->
                        <page string="📦 Lotes Generados (Stock)" name="lots">
                            <field name="lot_ids" readonly="1">
                                <list decoration-danger="volume_purchase_m3 == 0">
                                  <!--  <field name="name" string="Lote"/> -->
                                    <!-- NUEVO: Código de Etiqueta real (desde Excel, limpio) -->
                                    <field name="ref" string="Etiqueta" optional="show"/>
                                    <!-- Si además estás usando external_labels, puedes mostrarlo también:
                                    <field name="external_labels" string="Etiqueta Externa" optional="hide"/>
                                    -->
                                    <field name="product_id"/>
                                    <field name="espesor_mm" optional="show"/>
                                    <field name="ancho_mm" optional="show"/>
                                    <field name="largo_m" optional="show"/>
                                    <field name="piezas"/>
                                    <field name="volume_purchase_m3" sum="Total Vol"/>
                                    <field name="location_id" string="Ubicación"/>
                                </list>
                            </field>
                        </page>


                        <!-- PESTAÑA 6: ANÁLISIS HTML (Tu original) -->
                        <page string="📈 Resumen HTML" name="analysis">
                            <field name="reception_summary_html" widget="html" readonly="1"/>
                        </page>

                    </notebook>
                </sheet>
                
               <chatter/>
            </form>
        </field>
    </record>

    <!-- (El resto de vistas SEARCH y PENDING se mantienen intactas) -->
    
    <record id="view_lumber_reception_pending_list" model="ir.ui.view">
        <field name="name">lumber.reception.pending.list</field>
        <field name="model">lumber.reception</field>
        <field name="arch" type="xml">
            <list string="🚨 Recepciones Pendientes de Vinculación">
                <field name="name" string="Guía"/>
                <field name="supplier_id" string="Proveedor"/>
                <field name="purchase_order" string="OC Referencia"/>
                <field name="commercial_volume_m3" string="Vol. Comercial m³" digits="[16, 3]"/>
                <field name="physical_volume_m3" string="Vol. Físico m³" digits="[16, 3]"/>
                <field name="volume_variance_percent" string="Diferencia %"/>
                <button name="action_link_to_existing_po" type="object" 
                        string="Vincular OC" class="btn-primary"/>
            </list>
        </field>
    </record>

    <record id="view_madenat_audit_log_list" model="ir.ui.view">
        <field name="name">madenat.audit.log.tree</field>
        <field name="model">madenat.audit.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="timestamp"/>
                <field name="action_type"/>
                <field name="description"/>
                <field name="user_id"/>
                <field name="batch_id"/>
                <field name="month"/>
            </list>
        </field>
    </record>
    
    <record id="view_madenat_audit_log_search" model="ir.ui.view">
        <field name="name">madenat.audit.log.search</field>
        <field name="model">madenat.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="description"/>
                <field name="user_id"/>
                <field name="batch_id"/>
                <filter string="Omisiones" name="filter_omissions" 
                        domain="[('action_type', '=', 'omission')]"/>
                <filter string="Creaciones" name="filter_creations" 
                        domain="[('action_type', '=', 'creation')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Mes" name="group_by_month" context="{'group_by': 'month'}"/>
                    <filter string="Lote" name="group_by_lot" context="{'group_by': 'batch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_lumber_reception" model="ir.actions.act_window">
        <field name="name">Recepción de Guías</field>
        <field name="res_model">lumber.reception</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cree una nueva recepción de guía.
            </p>
        </field>
    </record>
    
    <record id="action_lumber_reception_pending" model="ir.actions.act_window">
        <field name="name">🚨 Recepciones Pendientes</field>
        <field name="res_model">lumber.reception</field>
        <field name="view_mode">list,form</field>
        <!-- Mantenemos la vista específica si te gusta su diseño simplificado -->
        <field name="view_id" ref="view_lumber_reception_pending_list"/>
        
        <!-- CORRECCIÓN DEL DOMINIO: Ahora incluye Borrador y Verificado -->
        <field name="domain">[('state', 'in', ['draft', 'verified'])]</field>
        
        <!-- Quitamos el contexto antiguo que podría filtrar de más -->
        <field name="context">{}</field>
    </record>


    <record id="action_madenat_audit_logs" model="ir.actions.act_window">
        <field name="name">Auditoría MADENAT</field>
        <field name="res_model">madenat.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_madenat_audit_log_list"/>
        <field name="context">{'search_default_group_by_month': 1}</field>
    </record>

</odoo>
