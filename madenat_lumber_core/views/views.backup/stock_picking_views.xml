<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">
    <!-- Vista FORM - Solo cambiar atributos del campo (esto sabemos que funciona) -->
    <record id="view_stock_picking_form_madenat" model="ir.ui.view">
      <field name="name">stock.picking.form.madenat</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_form"/>
      <field name="priority">16</field>
      <field name="arch" type="xml">
        <!-- Solo cambiar el string del campo move_line_ids -->
        <field name="move_line_ids" position="attributes">
          <attribute name="string">Productos MADENAT</attribute>
        </field>
      </field>
    </record>

    <!-- LIST VIEW para stock.picking (esto sabemos que funciona) -->
    <record id="view_stock_picking_tree_madenat" model="ir.ui.view">
      <field name="name">stock.picking.list.madenat</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.vpicktree"/>
      <field name="priority">16</field>
      <field name="arch" type="xml">
        <field name="scheduled_date" position="before">
          <field name="picking_type_code" string="Tipo" invisible="1"/>
        </field>
      </field>
    </record>

    <!-- SEARCH VIEW (esto sabemos que funciona) -->
    <record id="view_stock_picking_search_madenat" model="ir.ui.view">
      <field name="name">stock.picking.search.madenat</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_internal_search"/>
      <field name="priority">16</field>
      <field name="arch" type="xml">
        <search>
          <field name="name"/>
          <filter string="Recepciones MADENAT" name="incoming_pickings" 
                  domain="[('picking_type_code','=','incoming')]"/>
          <filter string="Entregas MADENAT" name="outgoing_pickings" 
                  domain="[('picking_type_code','=','outgoing')]"/>
        </search>
      </field>
    </record>
  </data>
</odoo>