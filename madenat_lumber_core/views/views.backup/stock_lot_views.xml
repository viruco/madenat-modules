<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">
    
    <!-- Vista Lista MEJORADA - SEPARACIÓN CÓDIGO/NOMBRE -->
    <record id="view_stock_lot_list_madenat" model="ir.ui.view">
      <field name="name">stock.lot.list.madenat</field>
      <field name="model">stock.lot</field>
      <field name="priority">1</field>
      <field name="arch" type="xml">
        <list string="Lotes MADENAT">
          <field name="name" string="Lote"/>
          
          <!-- ✅ REGLA DE ORO: SEPARAR CÓDIGO Y NOMBRE (usando campos computados existentes) -->
          <field name="product_code_only" string="Código" readonly="1" optional="hide"/> <!-- Oculto por defecto para limpiar -->
          <field name="product_name_only" string="Producto Maestro" readonly="1" optional="hide"/> <!-- Oculto por defecto -->

          <!-- 🔥 NUEVO CAMPO: Nombre Real del Excel -->
          <field name="note" string="Producto Original (Excel)" optional="show" decoration-bf="1"/>

          <field name="espesor_mm" string="Espesor (mm)" optional="show"/>
          <field name="ancho_mm" string="Ancho (mm)" optional="show"/>
          <field name="largo_m" string="Largo (m)" optional="show"/>

          <field name="piezas" string="Piezas" optional="show"/>
          <field name="purchase_order_id" string="OC" optional="show"/>
          <field name="guia_number" string="N° Guía" optional="show"/>
          <field name="volumen_m3" string="Vol m³" sum="Total m³"/>
          <field name="volumen_mbf" string="Vol MBF" sum="Total MBF"/>
          <field name="volume_purchase_m3" string="Vol Compra m³" optional="show" sum="Total"/>
          <field name="vol_shipment_m3" string="Vol Embarque m³" optional="show" sum="Total"/>
          <field name="estado_trazabilidad" string="Estado" widget="badge" optional="show"/>
          <field name="purchase_price_usd_per_m3" string="Precio USD/m³" optional="hide"/>
          <field name="sale_price_usd_per_mbf" string="Precio Venta USD/MBF" optional="hide"/>
          <field name="margin_percent" string="Margen %" widget="percentage" optional="show"/>
          <field name="technical_validation" string="Val. Técnica" widget="badge"
                 decoration-success="technical_validation == 'approved'"
                 decoration-warning="technical_validation == 'pending'"
                 decoration-danger="technical_validation == 'rejected'"/>
          <field name="financial_validation" string="Val. Financiera" 
                 groups="stock.group_stock_manager" widget="badge"
                 decoration-success="financial_validation == 'approved'"
                 decoration-warning="financial_validation == 'pending'"
                 decoration-danger="financial_validation == 'rejected'"/>
        </list>
      </field>
    </record>

    <!-- Vista Formulario COMPLETA CON VOLUMEN DUAL Y GENEALOGÍA INTEGRADA -->
    <!-- MANTENIDA EXACTAMENTE IGUAL AL ORIGINAL, SOLO AGREGANDO NOTE -->
    <record id="view_stock_lot_form_madenat" model="ir.ui.view">
      <field name="name">stock.lot.form.madenat</field>
      <field name="model">stock.lot</field>
      <field name="priority">1</field>
      <field name="arch" type="xml">
        <form string="Lote MADENAT">
          <header>
            <button name="action_approve_technical" string="✅ Aprobar Técnico" 
                    type="object" class="oe_highlight"
                    invisible="technical_validation != 'pending'"/>
            <button name="action_approve_financial" string="💰 Aprobar Financiero" 
                    type="object" class="oe_highlight"
                    invisible="financial_validation != 'pending'"
                    groups="stock.group_stock_manager"/>
            <field name="technical_validation" widget="statusbar"/>
            <field name="financial_validation" widget="statusbar" groups="stock.group_stock_manager"/>
          </header>
          
          <sheet>
            <!-- Información Principal -->
            <div class="oe_title">
              <h1>
                <field name="name" readonly="1"/>
              </h1>
              <!-- Agregado campo note aquí para que sea visible en form también -->
              <h3><field name="note" placeholder="Descripción Original" readonly="1"/></h3>
            </div>

            <!-- Botón de Genealogía (CORREGIDO: type="object") -->
            <div class="oe_button_box" name="button_box" invisible="generation_level == 0 and not parent_lot_id">
                <button class="oe_stat_button" 
                        type="object" 
                        name="action_view_lot_genealogy"
                        icon="fa-sitemap"
                        invisible="not parent_lot_id and not child_lot_ids">
                    <div class="o_stat_info">
                        <field name="generation_level" class="o_stat_value"/>
                        <span class="o_stat_text">Generación</span>
                    </div>
                </button>
            </div>

            <!-- Información Básica MEJORADA -->
            <group string="Información Básica">
              <group>
                <!-- ✅ REGLA DE ORO: SEPARAR CÓDIGO Y NOMBRE EN FORMULARIO -->
                <field name="product_code_only" string="Código Producto" readonly="1"/>
                <field name="product_name_only" string="Nombre Producto" readonly="1"/>
                <field name="piezas" string="N° Piezas"/>
                <field name="subproducto_id" string="Sub-producto"/>
                <field name="external_labels" 
                       invisible="not external_labels"
                       readonly="1"
                       string="Código Externo"/>
              </group>
              <group>
                <field name="reception_id" string="Recepción Origen" readonly="1"/>
                <field name="purchase_order_id" string="Orden de Compra"/>
                <field name="guia_number" string="Número de Guía"/>
                <field name="supplier_id" string="Proveedor"/>
              </group>
            </group>

            <!-- Trazabilidad y Estado -->
            <group string="📍 Trazabilidad">
              <group>
                <field name="estado_trazabilidad" string="Estado Actual" widget="badge"/>
              </group>
              <group>
                  <field name="location_id" string="Patio Actual" />
                <field name="company_id" invisible="1"/>
              </group>
            </group>

            <!-- Dimensiones y Volúmenes -->
            <group string="📐 Dimensiones y Volúmenes" col="4">
              <group string="Dimensiones Métricas">
                <field name="espesor_mm" string="Espesor (mm)"/>
                <field name="ancho_mm" string="Ancho (mm)"/>
                <field name="largo_m" string="Largo (m)"/>
              </group>
              <group string="Dimensiones Fraccionarias" invisible="1">
                <field name="espesor_inch_frac" string="Espesor (pulg)"/>
                <field name="ancho_inch_frac" string="Ancho (pulg)"/>
                <field name="largo_ft_frac" string="Largo (pies)"/>
              </group>
              <group string="Volúmenes">
                <field name="volumen_m3" string="Volumen m³" readonly="1" 
                       widget="monetary" options="{'currency_field': False}"/>
                <field name="volumen_mbf" string="Volumen MBF" readonly="1"
                       widget="monetary" options="{'currency_field': False}"/>
              </group>
            </group>

            <!-- Volumen Dual -->
            <group string="📊 Volumen Dual: Compra vs Embarque" col="4">
              <group string="Volumen Original (Compra)">
                <field name="volume_purchase_m3" string="Volumen Compra (m³)" 
                       help="Volumen al momento de compra (bruto, pre-cepillado)"/>
                <field name="thickness_final_inch" string="Espesor Final (pulg)" 
                       help="Espesor post-procesamiento"/>
              </group>
              <group string="Volumen Final (Embarque)">
                <field name="vol_shipment_m3" string="Volumen Embarque (m³)" 
                       help="Volumen para exportación (neto, post-cepillado)"/>
                <field name="width_final_inch" string="Ancho Final (pulg)" 
                       help="Ancho post-procesamiento"/>
              </group>
              <group string="Análisis de Transformación">
                <!-- Campo vacío para mantener estructura -->
              </group>
            </group>

            <!-- Notebook con pestañas -->
            <notebook>
              <!-- Pestaña: Valorización Compra -->
              <page string="💰 Valorización Compra">
                <group>
                  <group string="Datos de Compra">
                    <field name="purchase_price_usd_per_m3" string="Precio USD/m³"/>
                    <field name="purchase_exchange_rate" string="Tipo Cambio"/>
                  </group>
                  <group string="Montos Calculados">
                    <field name="purchase_amount_usd" string="Monto USD" readonly="1"/>
                    <field name="purchase_amount_clp" string="Monto CLP" readonly="1"/>
                  </group>
                </group>
              </page>

              <!-- Pestaña: Valorización Venta -->
              <page string="💵 Valorización Venta">
                <group>
                  <group string="Precio de Venta">
                    <field name="sale_price_usd_per_mbf" string="Precio USD/MBF"/>
                  </group>
                  <group string="Análisis de Margen">
                    <field name="sale_amount_usd" string="Venta USD" readonly="1"/>
                    <field name="margin_usd" string="Margen USD" readonly="1"/>
                    <field name="margin_percent" string="Margen %" readonly="1" widget="percentage"/>
                  </group>
                </group>
              </page>

              <!-- Pestaña: Gestión de Costos -->
              <page string="💸 Gestión de Costos">
                <group string="💰 Resumen de Costos">
                  <group string="Costos Totales">
                  </group>
                  <group string="Costos Unitarios">
                    <field name="cost_per_m3_usd" string="Costo por m³ (USD)" readonly="1"/>
                    <field name="cost_per_mbf_usd" string="Costo por MBF (USD)" readonly="1"/>
                  </group>
                </group>
                
                <!-- Detalle de líneas de costo -->
                <separator string="Detalle de Costos"/>
                <field name="cost_line_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="name" string="Descripción"/>
                    <field name="cost_type" string="Tipo"/>
                    <field name="amount_usd" string="Monto USD" sum="Total"/>
                    <field name="date" string="Fecha"/>
                  </list>
                </field>
              </page>

              <!-- Pestaña: Genealogía -->
              <page string="🌳 Genealogía" name="genealogy" 
                    invisible="not parent_lot_id and not child_lot_ids and not external_labels">
                  
                  <!-- Sección: Lote Padre -->
                  <group string="🔼 Lote Origen (Padre)" invisible="not parent_lot_id">
                      <group>
                          <field name="parent_lot_id" readonly="1" 
                                 context="{'form_view_ref': 'madenat_lumber_core.view_stock_lot_form_madenat'}"/>
                          <field name="origin_type" readonly="1"/>
                      </group>
                      <group>
                          <field name="generation_level" readonly="1"/>
                          <field name="processing_loss_pct" readonly="1" 
                                 widget="percentage"
                                 invisible="not parent_lot_id or processing_loss_pct == 0"/>
                      </group>
                  </group>
                  
                  <!-- Sección: Identificación Externa -->
                  <group string="🏷️ Identificación Externa">
                      <field name="external_labels" 
                             placeholder="Ej: D7731, CEPILLO-001, TACO-A45"
                             help="Códigos de etiquetas de proveedores externos (cepilladora, secadora, etc.)"/>
                  </group>
                  
                  <!-- Sección: Lotes Hijos (derivados) -->
                  <group string="🔽 Lotes Derivados (Hijos)" invisible="not child_lot_ids">
                      <field name="child_lot_ids" nolabel="1" 
                             context="{'tree_view_ref': 'madenat_lumber_core.view_stock_lot_tree_madenat'}">
                          <list create="0" delete="0">
                              <field name="name" string="Lote Hijo"/>
                              <field name="external_labels" string="Etiqueta"/>
                              <field name="vol_shipment_m3" string="Vol. (m³)" sum="Total"/>
                              <field name="processing_loss_pct" string="% Pérdida" widget="percentage"/>
                              <field name="estado_trazabilidad" string="Estado" widget="badge"/>
                          </list>
                      </field>
                  </group>
                  
                  <!-- Alert si hay múltiples niveles de transformación -->
                  <div class="alert alert-info" role="alert" 
                       invisible="generation_level &lt; 2">
                      <p><strong>ℹ️ Lote Multi-Generacional</strong></p>
                      <p>Este lote tiene <field name="generation_level" readonly="1"/> niveles de transformación desde el origen.</p>
                  </div>
                  
              </page>

              <!-- Pestaña: Consolidación -->
              <page string="📦 Consolidación" name="consolidation" 
                    invisible="estado_trazabilidad not in ['consolidado', 'embarcado']">
                <group string="Estado de Consolidación">
                  <field name="estado_trazabilidad" string="Estado" readonly="1" widget="badge"/>
                </group>
                <separator string="Nota"/>
                <div class="alert alert-info" role="alert">
                  <p>Este lote está en estado <strong><field name="estado_trazabilidad" readonly="1" nolabel="1"/></strong>.</p>
                  <p>Para ver detalles de consolidación, consulte el módulo de Logística.</p>
                </div>
              </page>

            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Vista de Búsqueda MEJORADA - Añadimos búsqueda por NOMBRE REAL -->
    <record id="view_stock_lot_search_madenat" model="ir.ui.view">
      <field name="name">stock.lot.search.madenat</field>
      <field name="model">stock.lot</field>
      <field name="priority">1</field>
      <field name="arch" type="xml">
        <search>
          <field name="name" string="Número de Lote"/>
          <field name="note" string="Nombre Original"/> <!-- 🔥 BÚSQUEDA AGREGADA -->
          <field name="product_id" string="Producto"/>
          <field name="reception_id" string="Recepción" readonly="1"/>
          <field name="purchase_order_id" string="OC"/>
          <separator/>
          <filter string="📦 Recepcionado" name="recepcionado"
                  domain="[('estado_trazabilidad','=','recepcionado')]"/>
          <filter string="🏭 En Patio" name="en_patio"
                  domain="[('estado_trazabilidad','=','en_patio')]"/>
          <filter string="✨ Procesado/Listo Exportación" name="procesado"
                  domain="[('estado_trazabilidad','=','procesado')]"/>
          <filter string="📋 Consolidado" name="consolidado"
                  domain="[('estado_trazabilidad','=','consolidado')]"/>
          <filter string="🚢 Embarcado" name="embarcado"
                  domain="[('estado_trazabilidad','=','embarcado')]"/>
          <separator/>
          <filter string="✅ Validados Técnicamente" name="technical_approved"
                  domain="[('technical_validation','=','approved')]"/>
          <filter string="⏳ Val. Técnica Pendiente" name="technical_pending"
                  domain="[('technical_validation','=','pending')]"/>
          <separator/>
          <filter string="✅ Validados Financieramente" name="financial_approved"
                  domain="[('financial_validation','=','approved')]"/>
          <filter string="⏳ Val. Financiera Pendiente" name="financial_pending"
                  domain="[('financial_validation','=','pending')]"/>
          <separator/>
          <filter string="📈 Con Margen Positivo" name="positive_margin"
                  domain="[('margin_percent','&gt;',0)]"/>
          <filter string="📉 Con Margen Negativo" name="negative_margin"
                  domain="[('margin_percent','&lt;',0)]"/>
          <separator/>
          <filter string="📊 Con Volumen Dual Registrado" name="with_dual_volume"
                  domain="[('volume_purchase_m3','&gt;',0),('vol_shipment_m3','&gt;',0)]"/>
          <group expand="0" string="Agrupar Por">
            <filter string="Producto" name="group_product" context="{'group_by':'product_id'}"/>
            <filter string="Nombre Original" name="group_note" context="{'group_by':'note'}"/> <!-- 🔥 AGRUPACIÓN AGREGADA -->
            <filter string="Recepción" name="group_reception" context="{'group_by':'reception_id'}"/>
            <filter string="Estado" name="group_estado" context="{'group_by':'estado_trazabilidad'}"/>
            <filter string="Val. Técnica" name="group_technical" context="{'group_by':'technical_validation'}"/>
          </group>
        </search>
      </field>
    </record>

  </data>
</odoo>
