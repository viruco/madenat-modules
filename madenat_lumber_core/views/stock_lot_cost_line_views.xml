<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="view_stock_lot_cost_line_list" model="ir.ui.view">
            <field name="name">stock.lot.cost.line.list</field>
            <field name="model">stock.lot.cost.line</field>
            <field name="arch" type="xml">
                <list string="Líneas de Costo" multi_edit="1" default_order="date desc, id desc">
                    
                    <field name="date" string="Fecha" optional="show"/>
                    
                    <field name="lot_id" string="Lote" optional="show" widget="many2one"/>
                    
                    <field name="name" string="Descripción"/>
                    
                    <field name="cost_type" 
                           string="Tipo" 
                           widget="badge" 
                           decoration-info="1"
                           optional="show"/>
                    
                    <field name="amount_usd" 
                           string="Monto USD" 
                           sum="Total Costos" 
                           widget="float" 
                           digits="[16, 2]"
                           decoration-bf="1"
                           decoration-danger="amount_usd &lt; 0"/>
                </list>
            </field>
        </record>

        <record id="view_stock_lot_cost_line_form" model="ir.ui.view">
            <field name="name">stock.lot.cost.line.form</field>
            <field name="model">stock.lot.cost.line</field>
            <field name="arch" type="xml">
                <form string="Línea de Costo">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Concepto / Descripción"/>
                            <h1>
                                <field name="name" placeholder="Ej: Flete Marítimo Internacional..."/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="cost_type" widget="radio" options="{'horizontal': true}"/>
                                <field name="date"/>
                            </group>
                            <group>
                                <field name="amount_usd" 
                                       widget="float" 
                                       digits="[16, 2]" 
                                       class="oe_inline" 
                                       style="font-size: 1.2em; font-weight: bold;"/>
                                <field name="lot_id" options="{'no_create': True}"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Detalles / Notas">
                                <field name="notes" 
                                       placeholder="Ingrese aquí detalles adicionales, número de factura del proveedor, etc..." 
                                       nolabel="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>