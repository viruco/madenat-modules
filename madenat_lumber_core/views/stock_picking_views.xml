<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">
    <record id="view_stock_picking_form_madenat" model="ir.ui.view">
      <field name="name">stock.picking.form.madenat</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_form"/>
      <field name="priority">16</field>
      <field name="arch" type="xml">
        <field name="move_line_ids" position="attributes">
          <attribute name="string">Productos MADENAT</attribute>
        </field>
      </field>
    </record>

    <record id="view_stock_picking_tree_madenat" model="ir.ui.view">
      <field name="name">stock.picking.list.madenat</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.vpicktree"/>
      <field name="priority">16</field>
      <field name="arch" type="xml">
        <field name="scheduled_date" position="before">
          <field name="picking_type_code" string="Tipo" invisible="1"/>
          <field name="lumber_reception_id" string="Guía Madenat" optional="show"/>
        </field>
        <field name="state" position="before">
            <field name="total_volume_m3" string="Total Guía (m³)" sum="Suma Total" optional="show" decoration-success="1" decoration-bf="1"/>
        </field>
      </field>
    </record>

    <record id="view_stock_picking_search_madenat" model="ir.ui.view">
      <field name="name">stock.picking.search.madenat</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_internal_search"/>
      <field name="priority">16</field>
      <field name="arch" type="xml">
        <xpath expr="//search" position="inside">
          <separator/>
          <field name="name" string="Albarán o Guía" filter_domain="['|', ('name', 'ilike', self), ('lumber_reception_id', 'ilike', self)]"/>
          <filter string="Recepciones MADENAT" name="incoming_pickings" domain="[('picking_type_code','=','incoming')]"/>
          <filter string="Entregas MADENAT" name="outgoing_pickings" domain="[('picking_type_code','=','outgoing')]"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>