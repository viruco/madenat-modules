<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">
    
    <record id="view_stock_lot_list_madenat_profesional" model="ir.ui.view">
        <field name="name">stock.lot.list.madenat.profesional</field>
        <field name="model">stock.lot</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list string="Lotes MADENAT" multi_edit="1" sample="1" decoration-muted="estado_trazabilidad == 'vendido'">
                <field name="ref" string="Código/Etiqueta" decoration-bf="1" optional="show"/>
                <field name="name" string="ID Interno" optional="hide"/>
               
                <field name="product_id" string="Producto" optional="show" context="{'display_default_code': False}"/>
                <field name="product_name_only" string="Producto Maestro" optional="hide"/>
                <field name="product_code_only" string="SKU" optional="hide"/>
                <field name="subproducto_id" 
                       string="Sub-Producto" 
                       optional="show" 
                       widget="badge"
                       decoration-success="subproducto_id"/>

                <field name="note" string="Desc. Excel" optional="show"/>
             
                <field name="espesor_mm" string="E (mm)" optional="show"/>
                <field name="ancho_mm" string="A (mm)" optional="show"/>
                <field name="largo_m" string="L (m)" optional="show"/>
                <field name="piezas" string="Pzas" sum="Total Piezas"/>

                <field name="volumen_m3" string="Vol Físico" sum="Total Físico" digits="[12,3]"/>
                <field name="vol_shipment_m3" 
                       string="Vol Embarque" 
                       sum="Total Embarque" 
                       decoration-success="1" 
                       decoration-bf="1" 
                       digits="[12,3]"/>
                <field name="location_id" string="Ubicación" optional="show"/>
                <field name="guia_number" string="Guía/Recepción" optional="show"/>
                <field name="estado_trazabilidad" string="Estado" widget="badge"/>
                <field name="technical_validation" string="Val. Técnica" widget="badge"
                       decoration-success="technical_validation == 'approved'"
                       decoration-warning="technical_validation == 'pending'"/>
                
                <field name="create_date" optional="hide"/>
                <field name="external_labels" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_stock_lot_form_madenat" model="ir.ui.view">
      <field name="name">stock.lot.form.madenat</field>
      <field name="model">stock.lot</field>
      <field name="priority">1</field>
      <field name="arch" type="xml">
        <form string="Lote MADENAT">
          <header>
            <button name="action_approve_technical" string="✅ Aprobar Técnico" 
                    type="object" class="oe_highlight"
                    invisible="technical_validation != 'pending'"/>
            <button name="action_approve_financial" string="💰 Aprobar Financiero" 
                    type="object" class="oe_highlight"
                    invisible="financial_validation != 'pending'"
                    groups="stock.group_stock_manager"/>
            <field name="technical_validation" widget="statusbar" statusbar_visible="pending,approved"/>
            <field name="financial_validation" widget="statusbar" statusbar_visible="pending,approved" groups="stock.group_stock_manager"/>
          </header>
          
          <sheet>
          <widget name="web_ribbon" title="VENDIDO" bg_color="text-bg-success" invisible="estado_trazabilidad != 'vendido'"/>
          <widget name="web_ribbon" title="EMBARCADO" bg_color="text-bg-info" invisible="estado_trazabilidad != 'consolidado'"/>

            <div class="oe_button_box" name="button_box">
                <button class="oe_stat_button" type="object" name="action_view_lot_genealogy"
                        icon="fa-sitemap" invisible="not parent_lot_id and not child_lot_ids">
                    <div class="o_stat_info">
                        <field name="generation_level" class="o_stat_value"/>
                        <span class="o_stat_text">Generación</span>
                    </div>
                </button>
            </div>

            <div class="oe_title">
              <label for="name" string="Número de Lote"/>
              <h1><field name="name" readonly="1"/></h1>
              <label for="note" string="Descripción Original del Excel"/>
              <h3><field name="note" placeholder="Nombre que venía en el archivo..." readonly="1" class="text-muted"/></h3>
            </div>

            <group string="📦 Información de Identificación">
              <group>
                <field name="product_code_only" string="Código Producto" readonly="1"/>
                <field name="product_name_only" string="Nombre Producto" readonly="1"/>
                
                <field name="piezas" string="N° Piezas" decoration-bf="1"/>
                <field name="subproducto_id" string="Sub-producto"/>
                <field name="external_labels" invisible="not external_labels" readonly="1" string="Código Externo"/>
              </group>
              <group>
                <field name="reception_id" string="Recepción Origen" readonly="1"/>
                <field name="purchase_order_id" string="Orden de Compra"/>
                <field name="guia_number" string="Número de Guía"/>
                <field name="supplier_id" string="Proveedor"/>
              </group>
            </group>

            <group string="📐 Dimensiones Métricas y Volumen">
              <group>
                <field name="espesor_mm" string="Espesor (mm)"/>
                <field name="ancho_mm" string="Ancho (mm)"/>
                <field name="largo_m" string="Largo (m)"/>
              </group>
              <group>
                <field name="volumen_m3" string="Volumen Físico (m³)" readonly="1" decoration-bf="1"/>
                <field name="volumen_mbf" string="Volumen MBF" readonly="1"/>
                <field name="estado_trazabilidad" string="Estado Actual" widget="badge"/>
              </group>
            </group>

            <group string="📊 Volumen Dual (Compra vs Embarque)" col="4">
              <group string="Origen (Compra)">
                <field name="volume_purchase_m3" string="Volumen Compra (m³)" class="text-primary"/>
                <field name="thickness_final_inch" string="Esp. Final (pulg)"/>
              </group>
              <group string="Final (Embarque)">
                <field name="vol_shipment_m3" string="Volumen Embarque (m³)" class="text-success" style="font-weight: bold;"/>
                <field name="width_final_inch" string="Ancho Final (pulg)"/>
              </group>
            </group>

            <notebook>
              <page string="💰 Valorización Compra">
                <group>
                  <group string="Datos de Compra">
                    <field name="purchase_price_usd_per_m3" string="Precio USD/m³"/>
                    <field name="purchase_exchange_rate" string="Tipo Cambio"/>
                  </group>
                  <group string="Montos Calculados">
                    <field name="purchase_amount_usd" string="Monto USD" readonly="1"/>
                    <field name="purchase_amount_clp" string="Monto CLP" readonly="1"/>
                  </group>
                </group>
              </page>

              <page string="💵 Valorización Venta">
                <group>
                  <group string="Precio de Venta">
                    <field name="sale_price_usd_per_mbf" string="Precio USD/MBF"/>
                  </group>
                  <group string="Análisis de Margen">
                    <field name="sale_amount_usd" string="Venta USD" readonly="1"/>
                    <field name="margin_usd" string="Margen USD" readonly="1"/>
                    <field name="margin_percent" string="Margen %" readonly="1" widget="percentage"/>
                  </group>
                </group>
              </page>

              <page string="💸 Gestión de Costos">
                <group string="💰 Resumen de Costos">
                  <group string="Costos Totales"/>
                  <group string="Costos Unitarios">
                    <field name="cost_per_m3_usd" string="Costo por m³ (USD)" readonly="1"/>
                    <field name="cost_per_mbf_usd" string="Costo por MBF (USD)" readonly="1"/>
                  </group>
                </group>
                <separator string="Detalle de Costos"/>
                <field name="cost_line_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="date" string="Fecha"/>
                    <field name="name" string="Descripción"/>
                    <field name="cost_type" string="Tipo" widget="badge"/>
                    <field name="amount_usd" string="Monto USD" sum="Total"/>
                  </list>
                </field>
              </page>

              <page string="🌳 Genealogía y Trazabilidad" name="genealogy" 
                    invisible="not parent_lot_id and not child_lot_ids and not external_labels">
                <group string="🔼 Lote Origen (Padre)" invisible="not parent_lot_id">
                    <group>
                        <field name="parent_lot_id" readonly="1" context="{'form_view_ref': 'madenat_lumber_core.view_stock_lot_form_madenat'}"/>
                        <field name="origin_type" readonly="1"/>
                    </group>
                    <group>
                        <field name="generation_level" readonly="1"/>
                        <field name="processing_loss_pct" readonly="1" widget="percentage" invisible="not parent_lot_id or processing_loss_pct == 0"/>
                    </group>
                </group>
                <group string="🏷️ Identificación Externa">
                    <field name="external_labels" placeholder="Ej: D7731..."/>
                </group>
                <group string="🔽 Lotes Derivados (Hijos)" invisible="not child_lot_ids">
                    <field name="child_lot_ids" nolabel="1">
                        <list create="0" delete="0">
                            <field name="name" string="Lote Hijo"/>
                            <field name="external_labels" string="Etiqueta"/>
                            <field name="vol_shipment_m3" string="Vol. (m³)" sum="Total"/>
                            <field name="processing_loss_pct" string="% Pérdida" widget="percentage"/>
                            <field name="estado_trazabilidad" string="Estado" widget="badge"/>
                        </list>
                    </field>
                </group>
              </page>
            </notebook>
          </sheet>
          <chatter/>
        </form>
      </field>
    </record>

    <record id="view_stock_lot_search_madenat" model="ir.ui.view">
      <field name="name">stock.lot.search.madenat</field>
      <field name="model">stock.lot</field>
      <field name="arch" type="xml">
        <search>
          <field name="name" string="Lote"/>
          <field name="note" string="Nombre Original (Excel)"/>
          <field name="product_id"/>
          <field name="reception_id"/>
          <field name="purchase_order_id"/>
          
          <separator/>
          <filter string="📦 Recepcionado" name="recepcionado" domain="[('estado_trazabilidad','=','recepcionado')]"/>
          <filter string="🏭 En Patio" name="en_patio" domain="[('estado_trazabilidad','=','en_patio')]"/>
          <filter string="✨ Procesado" name="procesado" domain="[('estado_trazabilidad','=','procesado')]"/>
          <separator/>
          <filter string="⏳ Val. Técnica Pendiente" name="technical_pending" domain="[('technical_validation','=','pending')]"/>
          <filter string="⏳ Val. Financiera Pendiente" name="financial_pending" domain="[('financial_validation','=','pending')]"/>
          <group expand="0" string="Agrupar Por">
            <filter string="Producto" name="group_product" context="{'group_by':'product_id'}"/>
            <filter string="Estado" name="group_estado" context="{'group_by':'estado_trazabilidad'}"/>
            <filter string="Nombre Original" name="group_note" context="{'group_by':'note'}"/>
            <filter string="Ubicación (Patio)" name="group_location" context="{'group_by':'location_id'}"/>
            <filter string="Proveedor" name="group_supplier" context="{'group_by':'supplier_id'}"/>
            <filter string="Orden de Compra" name="group_purchase" context="{'group_by':'purchase_order_id'}"/>
            <filter string="Guía de Recepción" name="group_reception" context="{'group_by':'reception_id'}"/>
          </group>

          <searchpanel>
           <field name="location_id" icon="fa-map-marker" string="Patios" enable_counters="1"/>
           <field name="estado_trazabilidad" icon="fa-tasks" string="Estado del Lote" enable_counters="1"/>
        </searchpanel>

        </search>
      </field>
    </record>

    <record id="view_stock_lot_pivot_base" model="ir.ui.view">
            <field name="name">stock.lot.pivot.base</field>
            <field name="model">stock.lot</field>
            <field name="arch" type="xml">
                <pivot string="Análisis de Lotes" sample="1">
                    <field name="product_id" type="row"/>
                    <field name="estado_trazabilidad" type="col"/>
                    <field name="volumen_m3" type="measure"/>
                    <field name="piezas" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="view_stock_lot_graph_base" model="ir.ui.view">
            <field name="name">stock.lot.graph.base</field>
            <field name="model">stock.lot</field>
            <field name="arch" type="xml">
                <graph string="Análisis de Lotes" type="bar" sample="1">
                    <field name="product_id"/>
                    <field name="volumen_m3" type="measure"/>
                </graph>
            </field>
        </record>

    <record id="action_madenat_list_commercial" model="ir.actions.act_window">
        <field name="name">📦 Listado Comercial (Según Compra)</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form,kanban,pivot,graph</field>
        <field name="context">{'search_default_group_purchase': 1}</field>
    </record>

    <record id="action_madenat_list_physical" model="ir.actions.act_window">
        <field name="name">📍 Listado Físico (Medidas Reales)</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form,kanban,pivot,graph</field>
        <field name="context">{'search_default_en_patio': 1, 'search_default_group_location': 1}</field>
    </record>

    <record id="action_madenat_list_export" model="ir.actions.act_window">
        <field name="name">🚢 Listado de Embarque (Exportación)</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form,kanban,pivot,graph</field>
        <field name="context">{'search_default_procesado': 1, 'search_default_group_product': 1}</field>
    </record>

    
  </data>
</odoo>