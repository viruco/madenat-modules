<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Panel de Conciliación — Perfil Contabilidad -->
        <record id="view_madenat_accounting_reconciliation_tree" model="ir.ui.view">
            <field name="name">madenat.accounting.reconciliation.tree</field>
            <field name="model">lumber.reception</field>
            <field name="arch" type="xml">
                <list string="Conciliación Contable" create="false" delete="false">
                    <field name="name" string="Recepción"/>
                    <field name="supplier_id" string="Proveedor"/>
                    <field name="total_amount_clp" string="Total CLP" widget="monetary"/>
                    <field name="total_amount_usd" string="Total USD" widget="monetary"/>
                    <field name="exchange_rate" string="Tasa Cambio"/>
                    <field name="state" string="Estado"/>
                    <field name="reconciliation_state" string="Conciliación" widget="badge"/>
                </list>
            </field>
        </record>

        <record id="action_madenat_accounting_reconciliation" model="ir.actions.act_window">
            <field name="name">Panel de Conciliación</field>
            <field name="res_model">lumber.reception</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_madenat_accounting_reconciliation_tree"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Panel de conciliación contable</p>
                <p>Revise recepciones pendientes de conciliación con factura de proveedor.</p>
            </field>
        </record>

    </data>
</odoo>
