<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- KANBAN OPERACIONAL — Recepciones de Madera                     -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <record id="view_lumber_reception_kanban_operational" model="ir.ui.view">
        <field name="name">lumber.reception.kanban.operational</field>
        <field name="model">lumber.reception</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" default_group_by="state" sample="1">
                <!-- Campos declarados — TODOS los usados en el template DEBEN estar aquí -->
                <field name="id"/>
                <field name="name"/>
                <field name="purchase_order"/>
                <field name="supplier_id"/>
                <field name="reception_date"/>
                <field name="state"/>
                <field name="commercial_volume_m3"/>
                <field name="physical_volume_m3"/>
                <field name="volume_variance_percent"/>
                <field name="total_packages"/>
                <field name="total_amount_clp"/>
                <field name="manual_po_name"/>
                <field name="ingestion_profile"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kanban_record">

                            <!-- ========== CABECERA ========== -->
                            <div class="o_kanban_record_head p-3 border-bottom">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <!-- Referencia OC -->
                                    <strong class="o_kanban_record_title" style="font-size: 1.05rem;">
                                        <t t-if="record.purchase_order.raw_value and record.purchase_order.raw_value != 'SIN ORDEN'">
                                            <t t-esc="record.purchase_order.value"/>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted">
                                                <t t-esc="record.manual_po_name.value or 'Sin OC'"/>
                                            </span>
                                        </t>
                                    </strong>
                                    <!-- Badge de estado -->
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'done'"
                                           decoration-info="state == 'draft' or state == 'processing'"
                                           decoration-warning="state == 'verified' or state == 'pending_link'"
                                           decoration-danger="state == 'error'"
                                           decoration-muted="state == 'cancel'"/>
                                </div>
                                <!-- Proveedor -->
                                <div class="o_kanban_record_subtitle text-muted small mb-1">
                                    <field name="supplier_id" widget="many2one_avatar"/>
                                </div>
                                <!-- Fecha -->
                                <div class="text-muted small">
                                    <i class="fa fa-calendar me-1" aria-hidden="true" title="Fecha"/> 
                                    <field name="reception_date" widget="date"/>
                                </div>
                            </div>

                            <!-- ========== CUERPO ========== -->
                            <div class="o_kanban_record_body p-3">

                                <!-- Volúmenes -->
                                <div class="d-flex justify-content-between mb-2">
                                    <div class="text-center" style="flex: 1;">
                                        <div class="text-muted small text-uppercase mb-1">Comercial</div>
                                        <strong style="color: #017e84;">
                                            <field name="commercial_volume_m3" digits="[16,3]"/>
                                        </strong>
                                        <div class="text-muted" style="font-size: 0.7rem;">m³</div>
                                    </div>

                                    <div class="text-center" style="flex: 1;">
                                        <div class="text-muted small text-uppercase mb-1">Físico</div>
                                        <strong style="color: #5b8999;">
                                            <field name="physical_volume_m3" digits="[16,3]"/>
                                        </strong>
                                        <div class="text-muted" style="font-size: 0.7rem;">m³</div>
                                    </div>

                                    <div class="text-center" style="flex: 1;">
                                        <div class="text-muted small text-uppercase mb-1">Paquetes</div>
                                        <strong>
                                            <field name="total_packages"/>
                                        </strong>
                                        <div class="text-muted" style="font-size: 0.7rem;">bultos</div>
                                    </div>
                                </div>

                                <!-- Barra de progreso visual -->
                                <div t-if="record.state.raw_value != 'cancel'" class="mt-2">
                                    <t t-if="record.state.raw_value == 'done'">
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-success" role="progressbar"
                                                 style="width: 100%" aria-valuenow="100"
                                                 aria-valuemin="0" aria-valuemax="100"/>
                                        </div>
                                        <div class="text-success small mt-1 fw-bold">
                                            <i class="fa fa-check-circle me-1" aria-hidden="true" title="Completo"/> 100% Recibido
                                        </div>
                                    </t>
                                    <t t-elif="record.state.raw_value == 'verified'">
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-warning" role="progressbar"
                                                 style="width: 75%" aria-valuenow="75"
                                                 aria-valuemin="0" aria-valuemax="100"/>
                                        </div>
                                        <div class="text-warning small mt-1 fw-bold">
                                            <i class="fa fa-clock-o me-1" aria-hidden="true" title="Verificado"/> Verificado — Pendiente confirmación
                                        </div>
                                    </t>
                                    <t t-elif="record.state.raw_value == 'processing'">
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-info" role="progressbar"
                                                 style="width: 50%" aria-valuenow="50"
                                                 aria-valuemin="0" aria-valuemax="100"/>
                                        </div>
                                        <div class="text-info small mt-1 fw-bold">
                                            <i class="fa fa-spinner me-1" aria-hidden="true" title="Procesando"/> Procesando documentos
                                        </div>
                                    </t>
                                    <t t-elif="record.state.raw_value == 'draft'">
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-secondary" role="progressbar"
                                                 style="width: 15%" aria-valuenow="15"
                                                 aria-valuemin="0" aria-valuemax="100"/>
                                        </div>
                                        <div class="text-muted small mt-1">
                                            <i class="fa fa-file-o me-1" aria-hidden="true" title="Borrador"/> Borrador
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-secondary" role="progressbar"
                                                 style="width: 10%" aria-valuenow="10"
                                                 aria-valuemin="0" aria-valuemax="100"/>
                                        </div>
                                    </t>
                                </div>

                                <!-- Alerta de variación si existe -->
                                <div t-if="record.volume_variance_percent.raw_value and record.volume_variance_percent.raw_value != 0
                                          and record.state.raw_value == 'verified'" 
                                     class="alert py-1 px-2 mt-2 mb-0 small"
                                     t-att-class="Math.abs(record.volume_variance_percent.raw_value) > 10
                                                  ? 'alert-danger'
                                                  : Math.abs(record.volume_variance_percent.raw_value) > 2
                                                    ? 'alert-warning'
                                                    : 'alert-success'">
                                    <i class="fa me-1"
                                       t-att-class="Math.abs(record.volume_variance_percent.raw_value) > 2
                                                    ? 'fa-exclamation-triangle'
                                                    : 'fa-check-circle'"
                                       aria-hidden="true" title="Alerta"/>
                                    Variación: 
                                    <strong>
                                        <field name="volume_variance_percent" widget="percentage"/>
                                    </strong>
                                </div>

                            </div>

                            <!-- ========== FOOTER ========== -->
                            <div class="o_kanban_record_footer border-top p-2 bg-light">
                                <div class="d-flex justify-content-between align-items-center">
                                    <!-- Perfil de ingesta -->
                                    <field name="ingestion_profile" widget="badge"
                                           decoration-info="ingestion_profile == 'f5085'"
                                           decoration-warning="ingestion_profile == 'f1550'"
                                           decoration-success="ingestion_profile == 'metric'"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ACCIÓN — Kanban Operacional de Recepciones                     -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <record id="action_lumber_reception_kanban" model="ir.actions.act_window">
        <field name="name">📋 Tablero de Recepciones</field>
        <field name="res_model">lumber.reception</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_lumber_reception_kanban_operational"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay recepciones registradas aún
            </p>
            <p>
                Las recepciones de madera aparecerán agrupadas por estado.
                Cada tarjeta representa una guía de despacho.
            </p>
        </field>
    </record>

</odoo>