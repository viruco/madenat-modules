<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Wizard de Cierre de Período (CANON/14, C20) -->
        <record id="action_madenat_period_close" model="ir.actions.act_window">
            <field name="name">Cierre de Período</field>
            <field name="res_model">madenat.period.close</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <record id="view_madenat_period_close_form" model="ir.ui.view">
            <field name="name">madenat.period.close.form</field>
            <field name="model">madenat.period.close</field>
            <field name="arch" type="xml">
                <form string="Cierre de Período">
                    <div class="alert alert-warning" role="alert">
                        <strong>El cierre de período verificará:</strong>
                        <ul>
                            <li>Embarques en tránsito con costos distribuidos (GB-4)</li>
                            <li>Recepciones finalizadas con conciliación contable (GB-5)</li>
                            <li>Lotes sin costo base asignado</li>
                            <li>Expedientes de liquidación validados por Contabilidad</li>
                        </ul>
                    </div>
                    <group>
                        <field name="confirm" string="He verificado los datos y deseo ejecutar el cierre"/>
                    </group>
                    <footer>
                        <button name="action_close_period" 
                                string="🔒 Ejecutar Cierre" 
                                type="object" 
                                class="btn-primary"
                                invisible="not confirm"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>