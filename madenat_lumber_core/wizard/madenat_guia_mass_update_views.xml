<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_madenat_guia_mass_update_form" model="ir.ui.view">
        <field name="name">madenat.guia.mass.update.form</field>
        <field name="model">madenat.guia.mass.update</field>
        <field name="arch" type="xml">
            <form string="Fijar valores comerciales masivos">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle" aria-hidden="true" title="Información"/>
                        Puede actualizar de forma masiva el <strong>espesor nominal</strong>,
                        el <strong>subproducto</strong> y/o el <strong>producto</strong>.
                        El espesor solo recalculará la fracción visual si se informa.
                    </div>
                    <group>
                        <group>
                            <field name="new_thickness_mm"
                                   placeholder="Opcional, ej: 45.0"
                                   class="oe_inline"/>
                        </group>
                        <group>
                            <field name="subproducto_id"
                                   placeholder="Opcional"
                                   options="{'no_open': True}"/>
                        </group>
                        <group>
                            <field name="product_id"
                                   placeholder="Opcional"
                                   options="{'no_open': True}"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" string="Aplicar Cambios" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_madenat_guia_mass_update" model="ir.actions.act_window">
        <field name="name">Fijar valores comerciales masivos</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">madenat.guia.mass.update</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_madenat_guia_mass_update_form"/>
    </record>
</odoo>