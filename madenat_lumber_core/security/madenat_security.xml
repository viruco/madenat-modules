<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_madenat" model="ir.module.category">
            <field name="name">MADENAT: Gestión Madera</field>
            <field name="description">Control de accesos para el flujo Trader de Madenat</field>
            <field name="sequence">1</field>
        </record>

        <record id="group_madenat_cost_auditor" model="res.groups">
            <field name="name">Auditor de Costos (Felipe)</field>
            <field name="category_id" ref="module_category_madenat"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_madenat_admin" model="res.groups">
            <field name="name">Administrador Madenat</field>
            <field name="category_id" ref="module_category_madenat"/>
            <field name="implied_ids" eval="[(4, ref('group_madenat_cost_auditor'))]"/>
        </record>
    
        <record id="group_lumber_config_manager" model="res.groups">
            <field name="name">Configurador de Reglas de Ingesta</field>
            <field name="category_id" ref="module_category_madenat"/>
            <field name="implied_ids" eval="[(4, ref('group_madenat_admin'))]"/>
            <field name="comment">Usuario autorizado a mantener las reglas de configuracion de ingesta (mapas, tolerancias, filtros).</field>
        </record>
    </data>
</odoo>