<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <record id="action_lots_costing_pending" model="ir.actions.act_window">
            <field name="name">Lotes Pendientes de Valorización</field>
            <field name="res_model">stock.lot</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_pending': 1}</field>
            <field name="domain">[]</field> 
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">¡Todo al día!</p>
                <p>No hay lotes pendientes de costeo básico. Cristhian ha procesado todas las recepciones.</p>
            </field>
        </record>
        
        <record id="action_cost_analysis" model="ir.actions.act_window">
            <field name="name">Consola de Rentabilidad Trader</field>
            <field name="res_model">stock.lot</field>
            <field name="view_mode">list,pivot,graph,form</field>
            <field name="context">{
                'search_default_shipment': 1, 
                'search_default_complete': 1,
                'pivot_measures': ['margin_usd', 'sale_amount_usd', 'total_cost_usd', 'volumen_m3'],
                'pivot_column_groupby': ['create_date:month'],
                'pivot_row_groupby': ['shipment_id', 'product_name_only'],
                'graph_measure': 'margin_usd',
                'graph_mode': 'bar',
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">📈 Inteligencia de Negocio Madenat</p>
                <p>Esta consola permite auditar el <strong>Margen Real</strong> de cada embarque.</p>
            </field>
        </record>

        <menuitem id="menu_lumber_cost_distribution"
                  name="💸 Distribuir Gastos (Wizard)"
                  parent="madenat_lumber_reports.menu_finance_costing"
                  action="action_lumber_cost_dist_server"
                  sequence="10"/>

        <menuitem id="menu_lots_costing_pending"
                  name="⚠️ Lotes sin Costear"
                  parent="madenat_lumber_reports.menu_finance_costing"
                  action="action_lots_costing_pending"
                  sequence="15"/>
        
        <menuitem id="menu_cost_analysis"
                  name="📊 Análisis de Rentabilidad"
                  parent="madenat_lumber_reports.menu_finance_costing"
                  action="action_cost_analysis"
                  sequence="20"/>
                  
    </data>
</odoo>