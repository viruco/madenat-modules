<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View (Tree View en versiones anteriores) -->
        <record id="view_account_expense_mapping_list" model="ir.ui.view">
            <field name="name">account.expense.mapping.list</field>
            <field name="model">account.expense.mapping</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="vendor_category"/>
                    <field name="expense_account_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_account_expense_mapping_form" model="ir.ui.view">
            <field name="name">account.expense.mapping.form</field>
            <field name="model">account.expense.mapping</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="vendor_category"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <!-- OPCIONES CORREGIDAS para Odoo 18 -->
                                <field name="expense_account_id" options="{'no_create': True}"/>
                                <field name="name" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_account_expense_mapping_search" model="ir.ui.view">
            <field name="name">account.expense.mapping.search</field>
            <field name="model">account.expense.mapping</field>
            <field name="arch" type="xml">
                <search>
                    <field name="vendor_category"/>
                    <field name="expense_account_id"/>
                    <filter string="Activos" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactivos" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_account_expense_mapping" model="ir.actions.act_window">
            <field name="name">Mapeo de Gastos por Categoría</field>
            <field name="res_model">account.expense.mapping</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Configura el mapeo entre categorías de proveedores y cuentas contables.
                </p>
                <p>
                    Asigna una cuenta de gastos específica para cada categoría de proveedor
                    para automatizar la contabilización de facturas.
                </p>
            </field>
        </record>
    </data>
</odoo>