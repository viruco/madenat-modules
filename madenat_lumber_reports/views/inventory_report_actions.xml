<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- 8 ir.actions.act_window — Inventario Recepción                      -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <!-- R1: Detalle por Patio — Todos Productos -->
    <record id="action_r1_detail_location" model="ir.actions.act_window">
        <field name="name">R1: Detalle por Patio — Todos Productos</field>
        <field name="res_model">lumber.reception.line</field>
        <field name="view_mode">list</field>
        <field name="domain">[('reception_id.state', '!=', 'cancelled')]</field>
        <field name="context">{'group_by': 'patio_label', 'search_default_filter_active': True}</field>
        <field name="view_id" ref="madenat_lumber_reports.view_lumber_reception_line_tree_detail"/>
    </record>

