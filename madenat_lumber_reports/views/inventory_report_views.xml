<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- List Views + Search View — Inventario Recepción                      -->
    <!-- ════════════════════════════════════════════════════════════════════ -->


    <!-- Tree View: DETALLE (13 columnas) -->
    <record id="view_lumber_reception_line_tree_detail" model="ir.ui.view">
        <field name="name">lumber.reception.line.tree.detail</field>
        <field name="model">lumber.reception.line</field>
        <field name="arch" type="xml">
            <list string="Detalle Inventario Recepción">
                <field name="patio_label" optional="hide"/>
                <field name="complete_location_name" optional="show"/>
                <field name="partner_name" optional="hide"/>
                <field name="reception_id"/>
                <field name="product_id"/>
                <field name="subproduct_id"/>
                <field name="lot_name"/>
                <field name="thickness_visual"/>
                <field name="width_visual"/>
                <field name="length"/>
                <field name="pieces"/>
                <field name="purchase_order_name" string="Orden Compra"/>
                <field name="vol_physical_m3"/>
                <field name="vol_mbf"/>
            </list>
        </field>
    </record>


    <!-- Tree View: RESUMEN (6 columnas) -->
    <record id="view_lumber_reception_line_tree_summary" model="ir.ui.view">
        <field name="name">lumber.reception.line.tree.summary</field>
        <field name="model">lumber.reception.line</field>
        <field name="arch" type="xml">
            <list string="Resumen Inventario Recepción">
                <field name="patio_label" optional="hide"/>
                <field name="product_id"/>
                <field name="subproduct_id"/>
                <field name="pieces" sum="Total Piezas"/>
                <field name="vol_physical_m3" sum="Total M3"/>
                <field name="vol_mbf" sum="Total MBF"/>
            </list>
        </field>
    </record>


    <!-- Tree View: RESUMEN POR PROVEEDOR (R6) -->
    <record id="view_lumber_reception_line_tree_summary_partner" model="ir.ui.view">
        <field name="name">lumber.reception.line.tree.summary.partner</field>
        <field name="model">lumber.reception.line</field>
        <field name="arch" type="xml">
            <list string="Resumen por Proveedor">
                <field name="partner_name" optional="hide"/>
                <field name="product_id"/>
                <field name="subproduct_id"/>
                <field name="pieces" sum="Total Piezas"/>
                <field name="vol_physical_m3" sum="Total M3"/>
                <field name="vol_mbf" sum="Total MBF"/>
            </list>
        </field>
    </record>


    <!-- Tree View: DETALLE POR PRODUCTO (R9) -->
    <record id="view_lumber_reception_line_tree_detail_product" model="ir.ui.view">
        <field name="name">lumber.reception.line.tree.detail.product</field>
        <field name="model">lumber.reception.line</field>
        <field name="arch" type="xml">
            <list string="Detalle por Producto">
                <field name="product_id" optional="hide"/>
                <field name="subproduct_name" optional="show"/>
                <field name="patio_label" optional="hide"/>
                <field name="partner_name" optional="hide"/>
                <field name="reception_id"/>
                <field name="thickness_visual"/>
                <field name="width_visual"/>
                <field name="length"/>
                <field name="pieces" sum="Total Piezas"/>
                <field name="vol_physical_m3" sum="Total M3"/>
                <field name="vol_mbf" sum="Total MBF"/>
            </list>
        </field>
    </record>


    <!-- Search View compartido para todos los reportes -->
    <record id="view_lumber_reception_line_search_inventory" model="ir.ui.view">
        <field name="name">lumber.reception.line.search.inventory</field>
        <field name="model">lumber.reception.line</field>
        <field name="arch" type="xml">
            <search string="Buscar Recepciones">
                <field name="reception_id"/>
                <field name="product_id"/>
                <field name="subproduct_id"/>
                <field name="lot_name"/>
                <field name="patio_label"/>
                <separator/>
                <filter name="filter_active" string="Activos"
                        domain="[('reception_id.state', '!=', 'cancelled')]"/>
                <separator/>
                <filter name="group_patio_label" string="Patio"
                        context="{'group_by': 'patio_label'}"/>
                <filter name="group_location" string="Patio (Ubicación Técnica)"
                        context="{'group_by': 'location_id'}"/>
                <filter name="group_product" string="Producto"
                        context="{'group_by': 'product_id'}"/>
                <filter name="group_subproduct" string="Subproducto"
                        context="{'group_by': 'subproduct_id'}"/>
                <filter name="group_partner" string="Proveedor"
                        context="{'group_by': 'partner_name'}"/>
                <field name="partner_name"/>
                <!-- CAMBIO: purchase_order_name → purchase_id -->
                <filter name="group_purchase" string="Orden de Compra"
                        context="{'group_by': 'purchase_id'}"/>
            </search>
        </field>
    </record>



    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Tree Views: STOCK REAL (stock.quant) — R1, R2, R5, R7, R9             -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <!-- R1: Detalle por Patio — Stock Real (stock.quant)   -->
    <!-- 13 columnas: negocio + trazabilidad + inventario      -->
    <!-- NOTA (2026-06-16): columna quantity removida por      -->
    <!-- redundante (quantity=1.0 en madera). Se mantienen     -->
    <!-- 13 columnas con la misma información de negocio.      -->
    <record id="view_stock_quant_tree_r1_detail_patio" model="ir.ui.view">
        <field name="name">stock.quant.tree.r1.detail</field>
        <field name="model">stock.quant</field>
        <field name="priority" eval="20"/>
        <field name="arch" type="xml">
            <list string="R1 — Detalle por Patio (Stock Real)"
                  decoration-bf="location_name == 'Sin Patio'">
                <field name="location_name" string="Patio" optional="hide"/>
                <field name="lot_id" string="Etiqueta Lote"/>
                <field name="lot_reception_date" string="Fecha Recepción" optional="show"/>
                <field name="lot_guia_number" string="N° Guía" optional="hide"/>
                <field name="lot_purchase_order" string="N° Orden" optional="hide"/>
                <field name="lot_supplier" string="Proveedor" optional="show"/>
                <field name="product_id" string="Producto"/>
                <field name="lot_subproducto" string="Subproducto" optional="show"/>
                <field name="lot_escuadria" string="Escuadría" optional="show"/>
                <field name="lot_largo_m" string="Largo (m)" optional="show"/>
                <field name="lot_piezas" string="Piezas" optional="show" sum="Total Piezas"/>
                <field name="lot_volumen_m3" string="Vol. (m³)" optional="show" sum="Total Vol."/>
                <field name="lot_container_name" string="Contenedor" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- R2: Resumen por Patio — Stock Real (stock.quant) -->
    <record id="view_stock_quant_tree_r2_summary_patio" model="ir.ui.view">
        <field name="name">stock.quant.tree.r2.summary</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <list string="R2 — Resumen por Patio (Stock Real)">
                <field name="location_name" optional="hide"/>
                <field name="product_id"/>
                <field name="lot_id" string="Lote"/>
                <field name="quantity" sum="Total Cantidad"/>
            </list>
        </field>
    </record>

    <!-- R5: Detalle por Proveedor — Stock Real (stock.quant) -->
    <record id="view_stock_quant_tree_r5_detail_partner" model="ir.ui.view">
        <field name="name">stock.quant.tree.r5.detail</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <list string="R5 — Detalle por Proveedor (Stock Real)">
                <field name="lot_supplier" string="Proveedor" optional="hide"/>
                <field name="location_name" string="Patio" optional="hide"/>
                <field name="lot_id" string="Lote"/>
                <field name="product_id"/>
                <field name="lot_guia_number" string="N° Guía" optional="show"/>
                <field name="lot_reception_date" string="Fecha Recepción" optional="show"/>
                <field name="lot_subproducto" string="Subproducto" optional="show"/>
                <field name="lot_escuadria" string="Escuadría" optional="show"/>
                <field name="lot_largo_m" string="Largo (m)" optional="show"/>
                <field name="lot_piezas" string="Piezas" optional="show" sum="Total Piezas"/>
                <field name="quantity" string="Stock" sum="Total Cantidad"/>
            </list>
        </field>
    </record>

    <!-- R7: Detalle por Orden de Compra — Stock Real (stock.quant) -->
    <record id="view_stock_quant_tree_r7_detail_purchase" model="ir.ui.view">
        <field name="name">stock.quant.tree.r7.detail</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <list string="R7 — Detalle por Orden de Compra (Stock Real)">
                <field name="lot_purchase_order" string="Orden de Compra" optional="hide"/>
                <field name="lot_id" string="Lote"/>
                <field name="location_name" string="Patio" optional="hide"/>
                <field name="product_id"/>
                <field name="lot_supplier" string="Proveedor" optional="show"/>
                <field name="lot_guia_number" string="N° Guía" optional="show"/>
                <field name="lot_reception_date" string="Fecha Recepción" optional="show"/>
                <field name="lot_subproducto" string="Subproducto" optional="show"/>
                <field name="lot_escuadria" string="Escuadría" optional="show"/>
                <field name="lot_largo_m" string="Largo (m)" optional="show"/>
                <field name="lot_piezas" string="Piezas" optional="show" sum="Total Piezas"/>
                <field name="quantity" string="Stock" sum="Total Cantidad"/>
            </list>
        </field>
    </record>

    <!-- R9: Detalle por Producto — Stock Real (stock.quant) -->
    <record id="view_stock_quant_tree_r9_detail_product" model="ir.ui.view">
        <field name="name">stock.quant.tree.r9.detail</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <list string="R9 — Detalle por Producto (Stock Real)">
                <field name="product_id" optional="hide"/>
                <field name="lot_subproducto" string="Subproducto" optional="show"/>
                <field name="location_name" string="Patio" optional="hide"/>
                <field name="lot_supplier" string="Proveedor" optional="show"/>
                <field name="lot_id" string="Lote"/>
                <field name="lot_guia_number" string="N° Guía" optional="show"/>
                <field name="lot_reception_date" string="Fecha Recepción" optional="show"/>
                <field name="lot_escuadria" string="Escuadría" optional="show"/>
                <field name="lot_largo_m" string="Largo (m)" optional="show"/>
                <field name="lot_piezas" string="Piezas" optional="show" sum="Total Piezas"/>
                <field name="quantity" string="Stock" sum="Total Cantidad"/>
            </list>
        </field>
    </record>

    <!-- Search View para stock.quant — Stock Real -->
    <record id="view_stock_quant_search_inventory" model="ir.ui.view">
        <field name="name">stock.quant.search.inventory</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <search string="Buscar Stock Real">
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="lot_id"/>
                <separator/>
                <filter name="filter_stock_real" string="Stock Real"
                        domain="[('quantity', '>', 0), ('location_id.usage', '=', 'internal'), ('lot_id.technical_validation', '!=', 'rejected')]"/>
                <separator/>
                <filter name="group_location" string="Por Patio"
                        context="{'group_by': 'location_id'}"/>
                <filter name="group_product" string="Por Producto"
                        context="{'group_by': 'product_id'}"/>
            </search>
        </field>
    </record>

</odoo>
