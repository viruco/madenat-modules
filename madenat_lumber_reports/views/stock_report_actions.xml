<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- FASE 2 — Stock Real: act_window para navegación directa              -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <record id="action_r1_stock_detail_patio" model="ir.actions.act_window">
        <field name="name">R1: Detalle por Patio — Stock Real</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="domain">[('quantity', '>', 0), ('location_id.usage', '=', 'internal')]</field>
        <field name="context">{'group_by': 'location_id', 'search_default_filter_stock_real': 1}</field>
        <field name="view_id" ref="view_stock_quant_tree_r1_detail_patio"/>
    </record>

    <record id="action_r2_stock_summary_patio" model="ir.actions.act_window">
        <field name="name">R2: Resumen por Patio — Stock Real</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="domain">[('quantity', '>', 0), ('location_id.usage', '=', 'internal')]</field>
        <field name="context">{'group_by': 'location_id', 'search_default_filter_stock_real': 1}</field>
        <field name="view_id" ref="view_stock_quant_tree_r2_summary_patio"/>
    </record>

    <record id="action_r5_stock_detail_partner" model="ir.actions.act_window">
        <field name="name">R5: Detalle por Proveedor — Stock Real</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="domain">[('quantity', '>', 0), ('location_id.usage', '=', 'internal')]</field>
        <field name="context">{'search_default_filter_stock_real': 1}</field>
        <field name="view_id" ref="view_stock_quant_tree_r5_detail_partner"/>
    </record>

    <record id="action_r7_stock_detail_purchase" model="ir.actions.act_window">
        <field name="name">R7: Detalle por OC — Stock Real</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="domain">[('quantity', '>', 0), ('location_id.usage', '=', 'internal')]</field>
        <field name="context">{'search_default_filter_stock_real': 1}</field>
        <field name="view_id" ref="view_stock_quant_tree_r7_detail_purchase"/>
    </record>

    <record id="action_r9_stock_detail_product" model="ir.actions.act_window">
        <field name="name">R9: Detalle por Producto — Stock Real</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="domain">[('quantity', '>', 0), ('location_id.usage', '=', 'internal')]</field>
        <field name="context">{'group_by': 'product_id', 'search_default_filter_stock_real': 1}</field>
        <field name="view_id" ref="view_stock_quant_tree_r9_detail_product"/>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- FASE 2 — Server Actions XLSX sobre stock.lot                         -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <record id="action_server_r1_stock_detail_xlsx" model="ir.actions.server">
        <field name="name">📊 R1 Stock Real — Detalle por Patio (XLSX)</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="binding_model_id" ref="stock.model_stock_quant"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_export_r1_stock_detail_xlsx()
        </field>
    </record>

    <record id="action_server_r2_stock_summary_xlsx" model="ir.actions.server">
        <field name="name">📊 R2 Stock Real — Resumen por Patio (XLSX)</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="binding_model_id" ref="stock.model_stock_quant"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_export_r2_stock_summary_location_xlsx()
        </field>
    </record>

    <record id="action_server_r5_stock_detail_partner_xlsx" model="ir.actions.server">
        <field name="name">📊 R5 Stock Real — Detalle por Proveedor (XLSX)</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="binding_model_id" ref="stock.model_stock_quant"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_export_r5_stock_detail_partner_xlsx()
        </field>
    </record>

    <record id="action_server_r7_stock_detail_purchase_xlsx" model="ir.actions.server">
        <field name="name">📊 R7 Stock Real — Detalle por OC (XLSX)</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="binding_model_id" ref="stock.model_stock_quant"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_export_r7_stock_detail_purchase_xlsx()
        </field>
    </record>

    <record id="action_server_r9_stock_detail_product_xlsx" model="ir.actions.server">
        <field name="name">📊 R9 Stock Real — Detalle por Producto (XLSX)</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="binding_model_id" ref="stock.model_stock_quant"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_export_r9_stock_detail_product_xlsx()
        </field>
    </record>

</odoo>
