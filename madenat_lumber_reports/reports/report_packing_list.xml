<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ACCIÓN DE REPORTE -->
    <record id="action_report_lumber_container_packing_list" model="ir.actions.report">
        <field name="name">Packing List de Contenedor</field>
        <field name="model">lumber.container</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">madenat_lumber_logistics.report_packing_list_template</field>
        <field name="report_file">madenat_lumber_logistics.report_packing_list_template</field>
        <field name="print_report_name">'Packing_List_%s' % object.name</field>
        <field name="binding_model_id" ref="madenat_lumber_logistics.model_lumber_container"/>
        <field name="binding_type">report</field>
    </record>

    <!-- TEMPLATE QWEB -->
    <template id="report_packing_list_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- ENCABEZADO -->
                        <div class="row mb-4">
                            <div class="col-12 text-center">
                                <h2>PACKING LIST DE CONTENEDOR</h2>
                                <h4><span t-field="o.name"/></h4>
                            </div>
                        </div>

                        <!-- DATOS GENERALES -->
                        <div class="row mb-4" style="border: 1px solid #ddd; padding: 10px;">
                            <div class="col-6">
                                <strong>Embarque:</strong> <span t-field="o.shipment_id"/><br/>
                                <strong>Booking:</strong> <span t-field="o.booking_ref"/><br/>
                                <strong>Nave:</strong> <span t-field="o.shipment_id.vessel_name"/>
                            </div>
                            <div class="col-6 text-right">
                                <strong>Sello:</strong> <span t-field="o.seal_number"/><br/>
                                <strong>Tipo:</strong> <span t-field="o.container_type"/><br/>
                                <strong>Fecha Carga:</strong> <span t-field="o.loading_date"/>
                            </div>
                        </div>

                        <!-- TABLA DE LOTES -->
                        <table class="table table-sm table-bordered">
                            <thead class="thead-light">
                                <tr>
                                    <th>Lote / Tarja</th>
                                    <th>Producto</th>
                                    <th class="text-center">Piezas</th>
                                    <th class="text-right">Volumen (m³)</th>
                                    <th class="text-right">Peso (kg)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.lot_ids" t-as="lot">
                                    <td><span t-field="lot.name"/></td>
                                    <td><span t-field="lot.product_id.name"/></td>
                                    <td class="text-center"><span t-field="lot.piezas"/></td>
                                    <td class="text-right"><span t-field="lot.volumen_m3"/></td>
                                    <td class="text-right"><span t-field="lot.weight"/></td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr class="font-weight-bold">
                                    <td colspan="2" class="text-right">TOTALES:</td>
                                    <td class="text-center"><span t-field="o.total_pieces"/></td>
                                    <td class="text-right"><span t-field="o.volume_m3"/></td>
                                    <td class="text-right"><span t-field="o.gross_weight_kg"/></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- FOOTER / FIRMAS -->
                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <hr style="width: 80%"/>
                                <p>Jefe de Patio</p>
                            </div>
                            <div class="col-6 text-center">
                                <hr style="width: 80%"/>
                                <p>Transportista</p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
