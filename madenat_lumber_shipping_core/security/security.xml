<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- CATEGORÍA DEL MÓDULO -->
        <record model="ir.module.category" id="module_category_shipping">
            <field name="name">Gestión de Transporte (Navieras)</field>
            <field name="description">Gestión de Buques, Viajes y Bookings.</field>
            <field name="sequence">20</field>
        </record>

        <!-- GRUPO: USUARIO (Solo Lectura) -->
        <record id="group_shipping_user" model="res.groups">
            <field name="name">Usuario (Solo Lectura)</field>
            <field name="category_id" ref="module_category_shipping"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Puede ver buques y viajes, pero no modificarlos.</field>
        </record>

        <!-- GRUPO: MANAGER (Control Total) -->
        <record id="group_shipping_manager" model="res.groups">
            <field name="name">Administrador de Transporte</field>
            <field name="category_id" ref="module_category_shipping"/>
            <field name="implied_ids" eval="[(4, ref('group_shipping_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Acceso total para crear, editar y eliminar buques y viajes.</field>
        </record>
    </data>
</odoo>
