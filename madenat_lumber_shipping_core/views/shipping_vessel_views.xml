<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shipping_vessel_tree" model="ir.ui.view">
        <field name="name">shipping.vessel.list</field>
        <field name="model">shipping.vessel</field>
        <field name="arch" type="xml">
            <list string="Motonaves">
                <field name="name"/>
                <field name="imo_number"/>
                <field name="vessel_type"/>
                <field name="capacity_teu" optional="hide"/>
                <field name="flag_country_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_shipping_vessel_form" model="ir.ui.view">
        <field name="name">shipping.vessel.form</field>
        <field name="model">shipping.vessel</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Ej: MSC ISABELLA"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="imo_number"/>
                            <field name="flag_country_id"/>
                        </group>
                        <group>
                            <field name="vessel_type"/>
                            <field name="capacity_teu"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
                hatter/>
            </form>
        </field>
    </record>

    <record id="action_shipping_vessel" model="ir.actions.act_window">
        <field name="name">Motonaves</field>
        <field name="res_model">shipping.vessel</field>
        <field name="view_mode">list,form</field>
    </record>

  <!-- MENUITEM ELIMINADO - 2025-12-05
    <menuitem id="menu_shipping_vessel"
              parent="menu_shipping_config"
              action="action_shipping_vessel"
              sequence="10"/>
    Ahora está en: madenat_lumber_logistics/views/logistics_menus.xml
    -->
</odoo>
