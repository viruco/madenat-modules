<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shipping_voyage_tree" model="ir.ui.view">
        <field name="name">shipping.voyage.list</field>
        <field name="model">shipping.voyage</field>
        <field name="arch" type="xml">
            <list string="Viajes" decoration-info="state=='draft'" decoration-success="state=='confirmed'">
                <field name="display_name"/>
                <field name="vessel_id"/>
                <field name="voyage_reference"/>
                <field name="port_of_loading"/>
                <field name="etd"/>
                <field name="port_of_discharge"/>
                <field name="eta"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_shipping_voyage_form" model="ir.ui.view">
        <field name="name">shipping.voyage.form</field>
        <field name="model">shipping.voyage</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,departed,arrived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name"/></h1>
                    </div>
                    <group>
                        <group string="Identificación">
                            <field name="vessel_id"/>
                            <field name="voyage_reference"/>
                        </group>
                        <group string="Itinerario">
                            <field name="port_of_loading"/>
                            <field name="etd"/>
                            <field name="port_of_discharge"/>
                            <field name="eta"/>
                        </group>
                    </group>
                </sheet>
                hatter/>
            </form>
        </field>
    </record>

    <record id="action_shipping_voyage" model="ir.actions.act_window">
        <field name="name">Viajes</field>
        <field name="res_model">shipping.voyage</field>
        <field name="view_mode">list,form</field>
    </record>

   <!-- ELIMINADO 2025-12-05 - Ahora en logistics_menus.xml
    <menuitem id="menu_shipping_voyage" 
              parent="menu_shipping_operations" 
              action="action_shipping_voyage" 
              sequence="10"/>
-->
</odoo>
