<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista de Lista para Inventario Valorizado -->
        <record id="view_product_valuated_inventory_tree" model="ir.ui.view">
            <field name="name">product.valuated.inventory.tree</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <tree string="Inventario Valorizado MADENAT">
                    <field name="default_code" string="Código"/>
                    <field name="name" string="Producto"/>
                    <field name="stock_m3" string="Stock (m³)" digits="[16, 3]"/>
                    <field name="average_cost_usd_m3" string="Costo Promedio m³ (USD)" digits="[16, 2]"/>
                    <field name="inventory_value_usd" string="Valor Inventario (USD)" digits="[16, 2]"/>
                </tree>
            </field>
        </record>

        <!-- Acción para Inventario Valorizado -->
        <record id="action_valuated_inventory" model="ir.actions.act_window">
            <field name="name">Inventario Valorizado</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_product_valuated_inventory_tree"/>
            <field name="search_view_id" ref="product.product_search_form_view"/>
            <field name="domain">[('type', '=', 'product')]</field>
            <field name="context">{'search_default_filter_available': 1}</field>
        </record>

        <!-- Menú para Inventario Valorizado -->
        <menuitem id="menu_valuated_inventory" 
                  name="Inventario Valorizado" 
                  parent="menu_madenat_inventory"
                  action="action_valuated_inventory"
                  sequence="30"/>
    </data>
</odoo>