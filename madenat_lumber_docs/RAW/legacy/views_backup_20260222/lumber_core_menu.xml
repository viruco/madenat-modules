<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- ================================================== -->
        <!-- ESTRUCTURA DE MENÚS INTEGRADA MADENAT -->
        <!-- ================================================== -->
        
        <menuitem id="menu_madenat_root" 
                  name="🌲 MADENAT Lumber" 
                  parent="stock.menu_stock_root" 
                  sequence="5"
                  groups="base.group_user"/>
        
        <menuitem id="menu_lumber_reception_pending" 
                  name="🚨 Recepciones Pendientes"
                  parent="menu_madenat_root"
                  action="action_lumber_reception_pending"
                  sequence="5"
                  groups="stock.group_stock_user"/>
                  
        <!-- ================================================== -->
        <!-- 1. CANAL DE COMPRA DIRECTA (MADERA BRUTA) -->
        <!-- ================================================== -->
        <!-- HOTFIX: Quitamos el dominio erróneo para desbloquear el servidor -->
        <record id="action_lumber_reception_raw_only" model="ir.actions.act_window">
            <field name="name">📦 Recepción Madera Bruta (Compra)</field>
            <field name="res_model">lumber.reception</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field> <!-- Dominio vacío por seguridad -->
            <field name="context">{}</field>
        </record>

        <menuitem id="menu_lumber_reception" 
                  name="📦 Recepción Madera Bruta (Proveedor)" 
                  parent="menu_madenat_root"
                  action="action_lumber_reception_raw_only" 
                  sequence="10"
                  groups="stock.group_stock_user"/>

        <!-- ================================================== -->
        <!-- 2. CANAL DE SERVICIOS (MADERA PROCESADA) -->
        <!-- ================================================== -->
        <menuitem id="menu_guia_processing_root"
                  name="🏭 Recepción Post-Proceso (Servicios)"
                  parent="menu_madenat_root"
                  sequence="15"
                  groups="stock.group_stock_user"/>

        <!-- Este menú SÍ funciona perfecto con su filtro -->
        <record id="action_guia_processing_list" model="ir.actions.act_window">
            <field name="name">Guías Procesadas</field>
            <field name="res_model">madenat.guia.processing</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_madenat_guia_processing_list"/>
            <field name="search_view_id" ref="view_madenat_guia_processing_search"/>
            <!-- REGLA DE ORO: Solo mostrar Servicios -->
            <field name="domain">[('tipo_recepcion', '!=', 'raw')]</field>
            <field name="context">{'search_default_filter_draft': 1, 'default_tipo_recepcion': 'service'}</field>
        </record>

        <menuitem id="menu_guia_processing_list"
                  name="Guías Procesadas"
                  parent="menu_guia_processing_root"
                  action="action_guia_processing_list"
                  sequence="10"
                  groups="stock.group_stock_user"/>
                  
        <!-- Auditoría -->
        <menuitem id="menu_madenat_audit" 
                  name="📊 Auditoría" 
                  parent="menu_madenat_root"
                  action="action_madenat_audit_logs" 
                  sequence="30"
                  groups="stock.group_stock_manager"/>
    </data>
</odoo>
