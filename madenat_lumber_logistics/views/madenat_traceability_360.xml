<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Vista de Trazabilidad 360 — Perfil Gerencia -->
        <record id="action_madenat_traceability_360" model="ir.actions.act_window">
            <field name="name">Trazabilidad 360</field>
            <field name="res_model">stock.lot</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'create': false, 'delete': false}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Trazabilidad completa de lotes</p>
                <p>Consulte el recorrido completo de cualquier lote: recepción → stock → contenedor → embarque.</p>
            </field>
        </record>

        <record id="view_madenat_traceability_360_tree" model="ir.ui.view">
            <field name="name">madenat.traceability.360.tree</field>
            <field name="model">stock.lot</field>
            <field name="arch" type="xml">
                <list string="Trazabilidad 360" create="false" delete="false">
                    <field name="name" string="Lote"/>
                    <field name="product_id"/>
                    <field name="supplier_id" string="Proveedor"/>
                    <field name="reception_id" string="Recepción Origen"/>
                    <field name="container_id" string="Contenedor"/>
                    <field name="export_shipment_id" string="Embarque"/>
                </list>
            </field>
        </record>

    </data>
</odoo>