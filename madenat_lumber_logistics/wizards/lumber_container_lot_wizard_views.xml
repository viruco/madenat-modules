<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_lot_export_list" model="ir.ui.view">
        <field name="name">stock.lot.export.list</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <list string="Lotes para Exportación">
                <field name="external_labels" string="Códigos" width="150px"/>
                <field name="product_id" string="Producto" width="250px" context="{'display_default_code': False}"/>
                <field name="espesor_inch_frac" string="Espesor"/>
                <field name="ancho_inch_frac" string="Ancho"/>
                <field name="largo_ft_frac" string="Largo (m.)"/>
                <field name="piezas" string="Piezas" sum="Total Piezas"/>
                <field name="vol_shipment_m3" string="Volumen (m³)" sum="Total Volumen" decoration-bf="1"/>
            </list>
        </field>
    </record>

    <record id="view_stock_lot_shipping_wizard_list" model="ir.ui.view">
        <field name="name">stock.lot.shipping.wizard.list</field>
        <field name="model">stock.lot</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <list string="Selección de Lotes" create="0" delete="0">
                <field name="ref" string="Etiqueta" width="160px" decoration-bf="1"/>
                
                <field name="product_id" string="Producto" width="280px" context="{'display_default_code': False}"/>
                
                <field name="subproducto_id" string="Sub-Prod." widget="badge" width="100px"/>

                <field name="espesor_mm" string="E (mm)" width="75px"/>
                <field name="ancho_mm" string="A (mm)" width="75px"/>
                <field name="largo_m" string="L (m)" width="75px"/>

                <field name="piezas" string="Pzas" width="70px" sum="Total"/>
                <field name="volumen_m3" string="Vol. Físico" width="100px" sum="Total" optional="show"/>
                <field name="vol_shipment_m3" string="Vol. Emb." width="110px" sum="Total" decoration-bf="1"/>
                <field name="volumen_mbf" string="Vol. MBF" width="100px" sum="Total" decoration-bf="1"/>

                <field name="guia_number" string="Guía/Rece" width="130px"/>
                <field name="location_id" string="Ubicación" width="130px" optional="show"/>
                
                <field name="note" column_invisible="True"/>
                <field name="name" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_lumber_container_lot_wizard_form" model="ir.ui.view">
        <field name="name">lumber.container.lot.wizard.form</field>
        <field name="model">lumber.container.lot.wizard</field>
        <field name="arch" type="xml">
            <form string="Asignar Lotes a Contenedor">
                <field name="available_lot_ids" invisible="1"/>
                <field name="weight_exceeds" invisible="1"/>
                <field name="volume_exceeds" invisible="1"/>

                <field name="selected_lot_ids"
                       nolabel="1"
                       domain="[('id', 'in', available_lot_ids)]"
                       context="{
                           'list_view_ref': 'madenat_lumber_logistics.view_stock_lot_shipping_wizard_list'
                       }"/>

                <field name="validation_message" widget="html" nolabel="1" 
                       invisible="not weight_exceeds and not volume_exceeds"/>

                <footer>
                    <button string="Asignar Lotes" name="action_assign" type="object" class="btn-primary" 
                            invisible="weight_exceeds or volume_exceeds"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>