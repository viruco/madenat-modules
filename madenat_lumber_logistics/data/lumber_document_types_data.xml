<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- DOCUMENTOS ESTÁNDAR DE EXPORTACIÓN -->
        
        <record id="doc_check_invoice" model="lumber.document.checklist">
            <field name="name">Factura Comercial (Commercial Invoice)</field>
            <field name="sequence">10</field>
            <field name="is_required">True</field>
            <field name="description">Factura final emitida al cliente.</field>
        </record>

        <record id="doc_check_packing" model="lumber.document.checklist">
            <field name="name">Packing List</field>
            <field name="sequence">20</field>
            <field name="is_required">True</field>
            <field name="description">Detalle de carga por contenedor y lote.</field>
        </record>

        <record id="doc_check_bl" model="lumber.document.checklist">
            <field name="name">Bill of Lading (B/L)</field>
            <field name="sequence">30</field>
            <field name="is_required">True</field>
            <field name="description">Conocimiento de embarque original o copy.</field>
        </record>

        <record id="doc_check_vgm" model="lumber.document.checklist">
            <field name="name">Certificado VGM</field>
            <field name="sequence">40</field>
            <field name="is_required">True</field>
            <field name="description">Peso Bruto Verificado.</field>
        </record>

        <record id="doc_check_origin" model="lumber.document.checklist">
            <field name="name">Certificado de Origen</field>
            <field name="sequence">50</field>
            <field name="is_required">False</field>
            <field name="description">Si aplica por tratado comercial.</field>
        </record>
        
        <record id="doc_check_phyto" model="lumber.document.checklist">
            <field name="name">Certificado Fitosanitario</field>
            <field name="sequence">60</field>
            <field name="is_required">True</field>
            <field name="description">Certificación SAG.</field>
        </record>

    </data>
</odoo>
