<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================================ -->
        <!-- VISTA FORM: Wizard de Generación de Factura                                -->
        <!-- ============================================================================ -->
        <record id="view_lumber_billing_invoice_wizard_form" model="ir.ui.view">
            <field name="name">lumber.billing.invoice.wizard.form</field>
            <field name="model">lumber.billing.invoice.wizard</field>
            <field name="arch" type="xml">
                <form string="Generar Factura de Cliente">
                    
                    <!-- Información de la consolidación -->
                    <group name="consolidation_info" string="Información de Origen">
                        <group>
                            <field name="consolidation_id" readonly="1"/>
                            <field name="customer_id" readonly="1"/>
                            <field name="shipment_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="currency_id" options="{'no_create': True}"/>
                            <field name="invoice_origin" readonly="1"/>
                        </group>
                    </group>

                    <!-- Parámetros de la factura -->
                    <group name="invoice_params" string="Parámetros de Facturación">
                        <group>
                            <field name="invoice_date"/>
                            <field name="invoice_date_due"/>
                        </group>
                        <group>
                            <field name="journal_id" options="{'no_create': True}"/>
                            <field name="payment_term_id" options="{'no_create': True}"/>
                            <!-- ✅ NUEVO CAMPO: Posición Fiscal (Crítico para Exportación) -->
                            <field name="fiscal_position_id" 
                                   placeholder="Automático (ej: Exportación)..." 
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <!-- Líneas de factura editables -->
                    <notebook>
                        <page string="Líneas de Factura" name="invoice_lines">
                            <field name="line_ids">
                                <list string="Productos" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="uom_id" options="{'no_create': True}"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal" sum="Total" readonly="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="consolidation_line_id" column_invisible="1"/>
                                </list>
                            </field>
                            
                            <!-- Total visible -->
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_amount" widget="monetary" 
                                       options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </page>

                        <page string="Notas" name="notes">
                            <field name="notes" placeholder="Notas internas para la factura..."/>
                        </page>
                    </notebook>

                    <!-- Botones de acción -->
                    <footer>
                        <button string="Generar Factura" 
                                name="action_create_invoice" 
                                type="object" 
                                class="btn-primary"
                                data-hotkey="v"/>
                        <button string="Cancelar" 
                                special="cancel" 
                                class="btn-secondary"
                                data-hotkey="z"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>