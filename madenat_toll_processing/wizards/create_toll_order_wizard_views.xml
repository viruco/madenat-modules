<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="view_create_toll_order_wizard_form" model="ir.ui.view">
        <field name="name">create.toll.order.wizard.form</field>
        <field name="model">create.toll.order.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Orden Procesamiento">
                <group>
                    <field name="processor_id"/>
                    <field name="process_type"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="process_cost_per_m3"/>
                    <field name="lead_time_days"/>
                </group>
                <footer>
                    <button string="Crear Orden" name="action_create_toll_order" 
                            type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- Acción desde lotes -->
    <record id="action_create_toll_order_from_lots" model="ir.actions.act_window">
        <field name="name">Crear Orden Procesamiento</field>
        <field name="res_model">create.toll.order.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="stock.model_stock_lot"/>
        <field name="binding_view_types">list</field>
    </record>
    
</odoo>