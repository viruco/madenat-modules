<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Action -->
    <record id="action_toll_processing_order" model="ir.actions.act_window">
        <field name="name">Órdenes Procesamiento</field>
        <field name="res_model">toll.processing.order</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear primera orden de procesamiento
            </p>
        </field>
    </record>
    
    <!-- MENÚ RAÍZ -->
    <!-- groups: Solo visible para usuarios del módulo -->
    <menuitem id="menu_toll_processing_root"
              name="Toll Processing"
              web_icon="stock,static/description/icon.png"
              groups="group_toll_processing_user"
              sequence="50"/>
    
    <!-- SUBMENÚ -->
    <menuitem id="menu_toll_processing_orders"
              name="Órdenes Procesamiento"
              parent="menu_toll_processing_root"
              action="action_toll_processing_order"
              groups="group_toll_processing_user"
              sequence="10"/>
    
</odoo>