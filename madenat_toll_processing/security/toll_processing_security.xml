<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record model="ir.module.category" id="module_category_toll_processing">
        <field name="name">Procesamiento Terceros (Toll)</field>
        <field name="description">Gestión de procesamiento externo de madera.</field>
        <field name="sequence">20</field>
    </record>

    <!-- Grupo Usuario -->
    <record id="group_toll_processing_user" model="res.groups">
        <field name="name">Usuario</field>
        <field name="category_id" ref="module_category_toll_processing"/>
    </record>

    <!-- Grupo Responsable (Manager) -->
    <record id="group_toll_processing_manager" model="res.groups">
        <field name="name">Responsable</field>
        <field name="category_id" ref="module_category_toll_processing"/>
        <field name="implied_ids" eval="[(4, ref('group_toll_processing_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>