<?xml version="1.0" encoding="utf-8"?>
<odoo>
  
  <record id="action_madenat_purchase_order" model="ir.actions.act_window">
    <field name="name">Consola de Compras Madera</field>
    <field name="res_model">purchase.order</field>
    <field name="view_mode">list,kanban,pivot,graph,form</field>
    <field name="search_view_id" ref="purchase.view_purchase_order_filter"/>
    
    <field name="context">{
      'default_is_shipped': True,
      'search_default_draft': 1,      
      'default_lumber_quality': 'col_a',
      'search_default_groupby_partner': 0
    }</field>

    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('madenat_lumber_purchasing.view_purchase_order_kpis_tree_madenat_pro')}),
        (0, 0, {'view_mode': 'kanban', 'view_id': ref('purchase.view_purchase_order_kanban')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('purchase.purchase_order_form')})
    ]"/>

    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        🌲 Consola de Compras Madenat
      </p>
    </field>
  </record>

  <menuitem id="menu_lumber_purchase"
            name="Compras de Madera"
            parent="purchase.menu_purchase_root"
            action="action_madenat_purchase_order"
            sequence="5"/>

</odoo>